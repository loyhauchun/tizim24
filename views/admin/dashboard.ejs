<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    .wrapper {
      max-width: 1100px;
      margin: 0 auto;
      padding: 20px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      gap: 10px;
      flex-wrap: wrap;
    }

    .brand {
      font-size: 28px;
      font-weight: bold;
      color: #fbbf24;
    }

    .menu {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .menu a {
      text-decoration: none;
      background: #1e293b;
      color: white;
      padding: 10px 14px;
      border-radius: 10px;
    }

    .card {
      background: #1e293b;
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 20px;
    }

    .stat {
      font-size: 32px;
      font-weight: bold;
      color: #fbbf24;
      margin-top: 8px;
    }

    .btn {
      display: inline-block;
      margin-top: 10px;
      background: #fbbf24;
      color: #111827;
      text-decoration: none;
      padding: 12px 16px;
      border-radius: 10px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="topbar">
      <div class="brand">Tizim24 Admin</div>
      <div class="menu">
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/products">Mahsulotlar</a>
        <a href="/admin/customers">Mijozlar</a>
        <a href="/admin/products/new">Mahsulot qo‘shish</a>
        <a href="/auth/logout">Chiqish</a>
      </div>
    </div>

    <div class="card">
      <div>Jami mahsulotlar soni</div>
      <div class="stat"><%= productCount %></div>
      <a class="btn" href="/admin/products/new">Yangi mahsulot qo‘shish</a>
    </div>
  </div>
</body>
</html>