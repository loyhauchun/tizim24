<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>

  <style>
    :root {
      --bg: #06111f;
      --panel: #0d1c33;
      --panel-2: #09162b;
      --line: rgba(255, 255, 255, 0.08);
      --text: #eef4ff;
      --muted: #8ea4c7;
      --accent: #fbbf24;
      --green: #22c55e;
      --red: #ef4444;
      --blue: #3b82f6;
      --yellow: #f59e0b;
      --shadow: 0 14px 38px rgba(0, 0, 0, 0.28);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 24%),
        var(--bg);
      color: var(--text);
    }

    body {
      padding: 10px 12px 30px;
    }

    .wrapper {
      max-width: 1720px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .brand {
      font-size: 30px;
      font-weight: 800;
      color: var(--accent);
      letter-spacing: -0.8px;
    }

    .menu {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .menu a {
      text-decoration: none;
      background: #12213a;
      color: #dce8fb;
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      font-size: 14px;
      font-weight: 700;
      transition: 0.18s ease;
    }

    .menu a:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.18);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 10px;
    }

    .stat-card {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 14px 16px;
    }

    .stat-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 24px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 6px;
      word-break: break-word;
    }

    .stat-value.accent { color: var(--accent); }
    .stat-value.green { color: #86efac; }
    .stat-value.red { color: #fca5a5; }
    .stat-value.blue { color: #93c5fd; }
    .stat-value.yellow { color: #fde68a; }

    .stat-sub {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
    }

    .workspace-top {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      padding: 14px 16px 10px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .panel-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 20px;
    }

    .panel-head .sub {
      margin-top: 4px;
      color: var(--muted);
      font-size: 12px;
    }

    .panel-body {
      padding: 12px 14px 14px;
    }

    .list {
      display: grid;
      gap: 8px;
      max-height: 420px;
      overflow-y: auto;
      scrollbar-width: thin;
    }

    .list::-webkit-scrollbar {
      width: 8px;
    }

    .list::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .item-card {
      background: #0b1730;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 12px;
    }

    .item-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .item-name {
      font-size: 14px;
      font-weight: 800;
      color: white;
      line-height: 1.2;
    }

    .item-cat {
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
    }

    .item-stock {
      font-size: 16px;
      font-weight: 800;
      color: var(--accent);
      white-space: nowrap;
    }

    .badge-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 84px;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .badge-low {
      background: rgba(239,68,68,0.12);
      color: #fecaca;
      border-color: rgba(239,68,68,0.18);
    }

    .badge-stale {
      background: rgba(245,158,11,0.12);
      color: #fde68a;
      border-color: rgba(245,158,11,0.18);
    }

    .badge-never {
      background: rgba(59,130,246,0.12);
      color: #93c5fd;
      border-color: rgba(59,130,246,0.18);
    }

    .item-meta {
      margin-top: 8px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .table-panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .table-toolbar {
      padding: 12px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .search-input {
      width: 320px;
      max-width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 14px;
      outline: none;
    }

    .search-input:focus {
      border-color: rgba(59,130,246,0.42);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .table-wrap {
      padding: 12px 14px 14px;
      overflow-x: auto;
    }

    .inventory-table {
      min-width: 1200px;
      display: grid;
      gap: 8px;
    }

    .table-header,
    .table-row {
      display: grid;
      grid-template-columns: 220px 120px 80px 90px 120px 120px 150px 150px 160px 120px;
      gap: 8px;
      align-items: center;
      border-radius: 14px;
    }

    .table-header {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      padding: 10px 12px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .table-item {
      background: linear-gradient(180deg, #0d1b33, #0a162b);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 10px 12px;
    }

    .table-row {
      color: white;
      font-size: 13px;
      line-height: 1.3;
    }

    .table-name {
      font-weight: 800;
      font-size: 14px;
    }

    .sum-accent {
      color: var(--accent);
      font-weight: 800;
    }

    .empty-box {
      background: #0b1730;
      border: 1px dashed rgba(255,255,255,0.10);
      border-radius: 14px;
      color: var(--muted);
      font-size: 14px;
      text-align: center;
      padding: 20px;
    }

    .signature {
      position: fixed;
      right: 16px;
      bottom: 8px;
      color: rgba(255,255,255,0.35);
      font-size: 12px;
      letter-spacing: 0.5px;
      user-select: none;
      pointer-events: none;
    }

    @media (max-width: 1300px) {
      .stats-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .workspace-top {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 700px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .brand {
        font-size: 26px;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="topbar">
      <div class="brand">Tizim24 Admin</div>

      <div class="menu">
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/products">Mahsulotlar</a>
        <a href="/admin/customers">Mijozlar</a>
        <a href="/admin/products/new">Mahsulot qo‘shish</a>
        <a href="/auth/logout">Chiqish</a>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Jami mahsulotlar</div>
        <div class="stat-value accent"><%= productCount %></div>
        <div class="stat-sub">Tizimdagi barcha mahsulotlar</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Jami qoldiq</div>
        <div class="stat-value blue"><%= Number(totalStockQty || 0).toLocaleString("uz-UZ") %></div>
        <div class="stat-sub">Ombordagi umumiy birliklar</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Omborga ketgan summa</div>
        <div class="stat-value red"><%= Number(totalPurchaseValue || 0).toLocaleString("uz-UZ") %></div>
        <div class="stat-sub">Tannarx bo‘yicha hisob</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Sotuv qiymati</div>
        <div class="stat-value green"><%= Number(totalRetailValue || 0).toLocaleString("uz-UZ") %></div>
        <div class="stat-sub">Sotuv narxi bo‘yicha hisob</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Kam qoldiq</div>
        <div class="stat-value yellow"><%= lowStockCount %></div>
        <div class="stat-sub">10 tadan kam qolganlar</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Sotilmay turganlar</div>
        <div class="stat-value blue"><%= staleCount %></div>
        <div class="stat-sub">30+ kun yoki umuman sotilmagan</div>
      </div>
    </div>

    <div class="workspace-top">
      <div class="panel">
        <div class="panel-head">
          <h2>Kam qoldiqdagi mahsulotlar</h2>
          <div class="sub">Omborda kam qolgan mahsulotlar eng yuqorida ko‘rinadi.</div>
        </div>

        <div class="panel-body">
          <% if (!lowStockProducts || lowStockProducts.length === 0) { %>
            <div class="empty-box">Kam qoldiqdagi mahsulotlar topilmadi.</div>
          <% } else { %>
            <div class="list">
              <% lowStockProducts.forEach(product => { %>
                <div class="item-card">
                  <div class="item-top">
                    <div>
                      <div class="item-name"><%= product.name %></div>
                      <div class="item-cat"><%= product.category || "Kategoriya yo‘q" %></div>
                    </div>

                    <div class="item-stock">
                      <%= Number(product.stock || 0).toLocaleString("uz-UZ") %> <%= product.unit %>
                    </div>
                  </div>

                  <div class="badge-row">
                    <span class="badge badge-low">Kam qoldiq</span>
                  </div>

                  <div class="item-meta">
                    Tannarx: <%= Number(product.purchasePrice || 0).toLocaleString("uz-UZ") %><br>
                    Sotuv narxi: <%= Number(product.salePrice || 0).toLocaleString("uz-UZ") %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <h2>Sotilmay turgan mahsulotlar</h2>
          <div class="sub">30 kundan beri sotilmagan yoki umuman sotilmagan mahsulotlar.</div>
        </div>

        <div class="panel-body">
          <% if (!staleProducts || staleProducts.length === 0) { %>
            <div class="empty-box">Sotilmay turgan mahsulotlar topilmadi.</div>
          <% } else { %>
            <div class="list">
              <% staleProducts.forEach(product => { %>
                <div class="item-card">
                  <div class="item-top">
                    <div>
                      <div class="item-name"><%= product.name %></div>
                      <div class="item-cat"><%= product.category || "Kategoriya yo‘q" %></div>
                    </div>

                    <div class="item-stock">
                      <%= Number(product.stock || 0).toLocaleString("uz-UZ") %> <%= product.unit %>
                    </div>
                  </div>

                  <div class="badge-row">
                    <% if (product.isNeverSold) { %>
                      <span class="badge badge-never">Umuman sotilmagan</span>
                    <% } else { %>
                      <span class="badge badge-stale">30+ kun sotilmagan</span>
                    <% } %>
                  </div>

                  <div class="item-meta">
                    Sotilgan miqdor: <%= Number(product.soldQty || 0).toLocaleString("uz-UZ") %><br>
                    Oxirgi sotilgan sana:
                    <%= product.lastSoldAt ? new Date(product.lastSoldAt).toLocaleString("uz-UZ") : "Yo‘q" %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="table-panel">
      <div class="panel-head">
        <h2>Umumiy ombor jadvali</h2>
        <div class="sub">Barcha mahsulotlar, qoldiq va ombordagi qiymat bir joyda.</div>
      </div>

      <div class="table-toolbar">
        <input
          type="text"
          id="searchInput"
          class="search-input"
          placeholder="Mahsulot yoki kategoriya bo‘yicha qidiring..."
        />
      </div>

      <div class="table-wrap">
        <div class="inventory-table">
          <div class="table-header">
            <div>Mahsulot</div>
            <div>Kategoriya</div>
            <div>Birlik</div>
            <div>Qoldiq</div>
            <div>Kirim narxi</div>
            <div>Sotuv narxi</div>
            <div>Tannarx summasi</div>
            <div>Sotuv summasi</div>
            <div>Oxirgi sotilgan</div>
            <div>Holat</div>
          </div>

          <div id="inventoryRows">
            <% if (!inventoryProducts || inventoryProducts.length === 0) { %>
              <div class="empty-box">Mahsulotlar topilmadi.</div>
            <% } else { %>
              <% inventoryProducts.forEach(product => { %>
                <div
                  class="table-item inventory-row"
                  data-name="<%= String(product.name || '').toLowerCase() %>"
                  data-category="<%= String(product.category || '').toLowerCase() %>"
                >
                  <div class="table-row">
                    <div class="table-name"><%= product.name %></div>
                    <div><%= product.category || "-" %></div>
                    <div><%= product.unit %></div>
                    <div><%= Number(product.stock || 0).toLocaleString("uz-UZ") %></div>
                    <div><%= Number(product.purchasePrice || 0).toLocaleString("uz-UZ") %></div>
                    <div><%= Number(product.salePrice || 0).toLocaleString("uz-UZ") %></div>
                    <div class="sum-accent"><%= Number(product.inventoryCost || 0).toLocaleString("uz-UZ") %></div>
                    <div class="sum-accent"><%= Number(product.inventoryRetail || 0).toLocaleString("uz-UZ") %></div>
                    <div><%= product.lastSoldAt ? new Date(product.lastSoldAt).toLocaleString("uz-UZ") : "Yo‘q" %></div>
                    <div>
                      <div class="badge-row">
                        <% if (product.isLowStock) { %>
                          <span class="badge badge-low">Kam</span>
                        <% } %>

                        <% if (product.isNeverSold) { %>
                          <span class="badge badge-never">Sotilmagan</span>
                        <% } else if (product.isStale) { %>
                          <span class="badge badge-stale">Sekin</span>
                        <% } %>

                        <% if (!product.isLowStock && !product.isStale && !product.isNeverSold) { %>
                          <span class="badge" style="background: rgba(34,197,94,0.12); color:#86efac; border-color: rgba(34,197,94,0.18);">Normal</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="signature">SharqTech</div>

  <script>
    const searchInput = document.getElementById("searchInput");
    const rows = Array.from(document.querySelectorAll(".inventory-row"));

    if (searchInput) {
      searchInput.addEventListener("input", function () {
        const q = (this.value || "").toLowerCase().trim();

        rows.forEach(row => {
          const name = row.dataset.name || "";
          const category = row.dataset.category || "";

          const show = !q || name.includes(q) || category.includes(q);
          row.style.display = show ? "" : "none";
        });
      });
    }
  </script>
</body>
</html>
