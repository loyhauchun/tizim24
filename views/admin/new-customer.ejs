<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yangi mijoz</title>
  <style>
    body { margin:0; font-family:Arial,sans-serif; background:#0f172a; color:white; }
    .wrapper { max-width:700px; margin:0 auto; padding:20px; }
    .box { background:#1e293b; padding:20px; border-radius:16px; }
    h1 { color:#fbbf24; margin-top:0; }
    .form-group { margin-bottom:14px; }
    label { display:block; margin-bottom:6px; }
    input, textarea {
      width:100%; padding:12px; border:none; border-radius:10px; box-sizing:border-box;
    }
    textarea { min-height:100px; resize:vertical; }
    button, .back {
      display:inline-block; margin-top:10px; background:#fbbf24; color:#111827;
      text-decoration:none; padding:12px 16px; border:none; border-radius:10px; font-weight:bold; cursor:pointer;
    }
    .back { background:#334155; color:white; margin-left:8px; }
    .error { background:#7f1d1d; color:#fecaca; padding:10px; border-radius:10px; margin-bottom:12px; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="box">
      <h1>Yangi mijoz qo‘shish</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/admin/customers/new" method="POST">
        <div class="form-group">
          <label>Ism / nomi</label>
          <input type="text" name="fullName" required />
        </div>

        <div class="form-group">
          <label>Telefon</label>
          <input type="text" name="phone" required />
        </div>

        <div class="form-group">
          <label>Manzil</label>
          <input type="text" name="address" />
        </div>

        <div class="form-group">
          <label>Izoh</label>
          <textarea name="note"></textarea>
        </div>

        <button type="submit">Saqlash</button>
        <a class="back" href="/admin/customers">Orqaga</a>
      </form>
    </div>
  </div>
</body>
</html>