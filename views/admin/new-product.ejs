<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yangi mahsulot</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    .wrapper {
      max-width: 700px;
      margin: 0 auto;
      padding: 20px;
    }

    .box {
      background: #1e293b;
      padding: 20px;
      border-radius: 16px;
    }

    h1 {
      color: #fbbf24;
      margin-top: 0;
    }

    .form-group {
      margin-bottom: 14px;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-size: 14px;
    }

    input, select, textarea {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 10px;
      box-sizing: border-box;
    }

    textarea {
      min-height: 100px;
      resize: vertical;
    }

    .checkbox {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .checkbox input {
      width: auto;
    }

    button, .back {
      display: inline-block;
      margin-top: 10px;
      background: #fbbf24;
      color: #111827;
      text-decoration: none;
      padding: 12px 16px;
      border: none;
      border-radius: 10px;
      font-weight: bold;
      cursor: pointer;
    }

    .back {
      background: #334155;
      color: white;
      margin-left: 8px;
    }

    .error {
      background: #7f1d1d;
      color: #fecaca;
      padding: 10px;
      border-radius: 10px;
      margin-bottom: 12px;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="box">
      <h1>Yangi mahsulot qo‘shish</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/admin/products/new" method="POST">
        <div class="form-group">
          <label>Mahsulot nomi</label>
          <input type="text" name="name" required />
        </div>

        <div class="form-group">
          <label>Kategoriya</label>
          <input type="text" name="category" />
        </div>

        <div class="form-group">
          <label>Birlik turi</label>
          <select name="unit" required>
            <option value="dona">dona</option>
            <option value="kg">kg</option>
            <option value="metr">metr</option>
            <option value="m2">m2</option>
            <option value="m3">m3</option>
          </select>
        </div>

        <div class="form-group">
          <label>Kirim narxi</label>
          <input type="number" name="purchasePrice" step="0.01" />
        </div>

        <div class="form-group">
          <label>Sotuv narxi</label>
          <input type="number" name="salePrice" step="0.01" required />
        </div>

        <div class="form-group">
          <label>Minimal narx</label>
          <input type="number" name="minPrice" step="0.01" />
        </div>

        <div class="form-group">
          <label>Qoldiq</label>
          <input type="number" name="stock" step="0.01" />
        </div>

        <div class="form-group">
          <label>Kod / SKU</label>
          <input type="text" name="sku" />
        </div>

        <div class="form-group checkbox">
          <input type="checkbox" name="allowDebt" checked />
          <label>Nasiyaga berish mumkin</label>
        </div>

        <div class="form-group">
          <label>Izoh</label>
          <textarea name="description"></textarea>
        </div>

        <button type="submit">Saqlash</button>
        <a class="back" href="/admin/dashboard">Orqaga</a>
      </form>
    </div>
  </div>
</body>
</html>