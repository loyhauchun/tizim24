<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mahsulotni tahrirlash</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    .wrapper {
      max-width: 700px;
      margin: 0 auto;
      padding: 20px;
    }

    .box {
      background: #1e293b;
      padding: 20px;
      border-radius: 16px;
    }

    h1 {
      color: #fbbf24;
      margin-top: 0;
    }

    .form-group {
      margin-bottom: 14px;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-size: 14px;
    }

    input, select, textarea {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 10px;
      box-sizing: border-box;
    }

    textarea {
      min-height: 100px;
      resize: vertical;
    }

    .checkbox {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }

    .checkbox input {
      width: auto;
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    button, .back, .delete-btn {
      display: inline-block;
      background: #fbbf24;
      color: #111827;
      text-decoration: none;
      padding: 12px 16px;
      border: none;
      border-radius: 10px;
      font-weight: bold;
      cursor: pointer;
    }

    .back {
      background: #334155;
      color: white;
    }

    .delete-form {
      margin: 0;
    }

    .delete-btn {
      background: #dc2626;
      color: white;
    }

    .error {
      background: #7f1d1d;
      color: #fecaca;
      padding: 10px;
      border-radius: 10px;
      margin-bottom: 12px;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="box">
      <h1>Mahsulotni tahrirlash</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/admin/products/edit/<%= product._id %>" method="POST">
        <div class="form-group">
          <label>Mahsulot nomi</label>
          <input type="text" name="name" value="<%= product.name %>" required />
        </div>

        <div class="form-group">
          <label>Kategoriya</label>
          <input type="text" name="category" value="<%= product.category %>" />
        </div>

        <div class="form-group">
          <label>Birlik turi</label>
          <select name="unit" required>
            <option value="dona" <%= product.unit === "dona" ? "selected" : "" %>>dona</option>
            <option value="kg" <%= product.unit === "kg" ? "selected" : "" %>>kg</option>
            <option value="metr" <%= product.unit === "metr" ? "selected" : "" %>>metr</option>
            <option value="m2" <%= product.unit === "m2" ? "selected" : "" %>>m2</option>
            <option value="m3" <%= product.unit === "m3" ? "selected" : "" %>>m3</option>
          </select>
        </div>

        <div class="form-group">
          <label>Kirim narxi</label>
          <input type="number" name="purchasePrice" step="0.01" value="<%= product.purchasePrice %>" />
        </div>

        <div class="form-group">
          <label>Sotuv narxi</label>
          <input type="number" name="salePrice" step="0.01" value="<%= product.salePrice %>" required />
        </div>

        <div class="form-group">
          <label>Minimal narx</label>
          <input type="number" name="minPrice" step="0.01" value="<%= product.minPrice %>" />
        </div>

        <div class="form-group">
          <label>Qoldiq</label>
          <input type="number" name="stock" step="0.01" value="<%= product.stock %>" />
        </div>

        <div class="form-group">
          <label>Kod / SKU</label>
          <input type="text" name="sku" value="<%= product.sku %>" />
        </div>

        <div class="checkbox">
          <input type="checkbox" name="allowDebt" <%= product.allowDebt ? "checked" : "" %> />
          <label>Nasiyaga berish mumkin</label>
        </div>

        <div class="checkbox">
          <input type="checkbox" name="isActive" <%= product.isActive ? "checked" : "" %> />
          <label>Faol mahsulot</label>
        </div>

        <div class="form-group">
          <label>Izoh</label>
          <textarea name="description"><%= product.description %></textarea>
        </div>

        <div class="actions">
          <button type="submit">Saqlash</button>
          <a class="back" href="/admin/products">Orqaga</a>
        </div>
      </form>

      <form class="delete-form" action="/admin/products/delete/<%= product._id %>" method="POST" onsubmit="return confirm('Rostdan ham o‘chirasizmi?')">
        <div class="actions">
          <button class="delete-btn" type="submit">Mahsulotni o‘chirish</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>