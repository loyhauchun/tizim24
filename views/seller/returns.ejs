<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Qaytimlar</title>

  <style>
    :root {
      --bg: #06111f;
      --panel: #0d1c33;
      --panel-2: #09162b;
      --line: rgba(255, 255, 255, 0.08);
      --text: #eef4ff;
      --muted: #8ea4c7;
      --accent: #fbbf24;
      --green: #22c55e;
      --green-2: #16a34a;
      --red: #ef4444;
      --red-2: #dc2626;
      --blue: #3b82f6;
      --yellow: #f59e0b;
      --shadow: 0 14px 38px rgba(0, 0, 0, 0.28);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 24%),
        var(--bg);
      color: var(--text);
    }

    body {
      padding: 10px 12px 30px;
    }

    .wrapper {
      max-width: 1680px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      min-height: 50px;
      flex-wrap: wrap;
    }

    .brand {
      margin: 0;
      font-size: 30px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.8px;
      color: var(--accent);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
      position: relative;
    }

    .action-btn {
      text-decoration: none;
      border-radius: 14px;
      padding: 11px 16px;
      font-size: 14px;
      font-weight: 800;
      transition: 0.18s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #dce8fb;
    }

    .action-btn:hover {
      transform: translateY(-1px);
    }

    .menu-toggle {
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #182c4b, #12213a);
      color: white;
      border-radius: 14px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.18s ease;
      box-shadow: var(--shadow);
      padding: 0;
    }

    .menu-toggle:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.22);
    }

    .menu-bars {
      width: 18px;
      height: 14px;
      display: grid;
      gap: 4px;
    }

    .menu-bars span {
      display: block;
      height: 2px;
      background: #fff;
      border-radius: 999px;
    }

    .menu-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      width: 270px;
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 10px;
      display: none;
      z-index: 100;
    }

    .menu-dropdown.open {
      display: block;
      animation: fadeDown 0.18s ease;
    }

    @keyframes fadeDown {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .menu-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      margin: 4px 6px 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .menu-links {
      display: grid;
      gap: 8px;
    }

    .menu-links a {
      text-decoration: none;
      color: white;
      background: linear-gradient(180deg, #142540, #102038);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      transition: 0.18s ease;
    }

    .menu-links a:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, #1a2f50, #152741);
      border-color: rgba(251,191,36,0.20);
    }

    .summary-bar {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 10px;
    }

    .summary-card {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 16px 18px;
    }

    .summary-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    .summary-value {
      font-size: 30px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.05;
      word-break: break-word;
    }

    .summary-sub {
      margin-top: 6px;
      color: var(--muted);
      font-size: 13px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .stat-card {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 14px 16px;
    }

    .stat-title {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 24px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 6px;
      color: white;
      word-break: break-word;
    }

    .stat-value.green { color: #86efac; }
    .stat-value.red { color: #fca5a5; }
    .stat-value.blue { color: #93c5fd; }
    .stat-value.yellow { color: #fde68a; }

    .stat-meta {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.3;
    }

    .filters-panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 14px;
      display: grid;
      gap: 12px;
    }

    .filters-top {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .period-btn {
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #dce8fb;
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .period-btn.active {
      background: linear-gradient(180deg, var(--accent), #f0b61d);
      color: #101722;
      border-color: rgba(251,191,36,0.22);
    }

    .filters-bottom {
      display: grid;
      grid-template-columns: minmax(240px, 1fr) 220px 220px 160px;
      gap: 10px;
      align-items: end;
    }

    .field {
      display: grid;
      gap: 6px;
    }

    .field label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 700;
    }

    .field input,
    .field select {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 14px;
      outline: none;
    }

    .field input:focus,
    .field select:focus {
      border-color: rgba(59,130,246,0.42);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .clear-date-btn {
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #dce8fb;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
      height: 44px;
    }

    .clear-date-btn:hover {
      border-color: rgba(251,191,36,0.20);
    }

    .table-panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .table-headbar {
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .table-headbar h2 {
      margin: 0;
      color: var(--accent);
      font-size: 20px;
    }

    .table-headbar .sub {
      color: var(--muted);
      font-size: 12px;
    }

    .returns-table-wrap {
      padding: 12px 14px 14px;
      overflow-x: auto;
    }

    .returns-table {
      min-width: 1080px;
      display: grid;
      gap: 8px;
    }

    .returns-row,
    .returns-header {
      display: grid;
      grid-template-columns: 170px 160px 140px 160px 140px 90px;
      gap: 8px;
      align-items: center;
      border-radius: 14px;
    }

    .returns-header {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      padding: 10px 12px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .return-item {
      background: linear-gradient(180deg, #0d1b33, #0a162b);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      overflow: hidden;
    }

    .returns-row {
      padding: 10px 12px;
    }

    .returns-cell {
      font-size: 13px;
      color: white;
      line-height: 1.25;
      word-break: break-word;
    }

    .returns-cell strong {
      font-size: 14px;
    }

    .badge-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .type-badge,
    .scope-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 96px;
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .type-refund {
      background: rgba(239,68,68,0.12);
      color: #fca5a5;
      border-color: rgba(239,68,68,0.18);
    }

    .type-exchange {
      background: rgba(34,197,94,0.12);
      color: #86efac;
      border-color: rgba(34,197,94,0.18);
    }

    .scope-customer {
      background: rgba(59,130,246,0.12);
      color: #93c5fd;
      border-color: rgba(59,130,246,0.18);
    }

    .scope-supplier {
      background: rgba(245,158,11,0.12);
      color: #fde68a;
      border-color: rgba(245,158,11,0.18);
    }

    .sum-cell {
      color: var(--accent);
      font-size: 18px;
      font-weight: 800;
      text-align: right;
    }

    .view-btn {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #233754, #1a2c46);
      color: white;
      border-radius: 10px;
      padding: 9px 10px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .view-btn:hover {
      transform: translateY(-1px);
    }

    .return-details {
      display: none;
      padding: 0 12px 12px;
    }

    .return-details.open {
      display: block;
    }

    .details-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 12px;
      display: grid;
      gap: 10px;
    }

    .details-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 12px;
    }

    .items-grid {
      display: grid;
      gap: 8px;
    }

    .item-card {
      background: #0b1730;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px 12px;
      color: white;
      font-size: 13px;
      line-height: 1.4;
    }

    .item-card strong {
      display: block;
      margin-bottom: 4px;
      font-size: 14px;
    }

    .note-box {
      background: #0b1730;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 12px;
      color: white;
      font-size: 13px;
      line-height: 1.5;
    }

    .empty-box {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px dashed rgba(255,255,255,0.10);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 24px;
      color: var(--muted);
      text-align: center;
      font-size: 14px;
    }

    .signature {
      position: fixed;
      right: 16px;
      bottom: 8px;
      color: rgba(255,255,255,0.35);
      font-size: 12px;
      letter-spacing: 0.5px;
      user-select: none;
      pointer-events: none;
    }

    @media (max-width: 1100px) {
      .summary-bar,
      .stats-grid,
      .filters-bottom {
        grid-template-columns: 1fr;
      }

      .summary-value {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeReturns = Array.isArray(returns) ? returns : [];

    const returnsForClient = safeReturns.map(ret => ({
      _id: String(ret._id || ""),
      returnType: ret.returnType || "refund",
      returnScope: ret.returnScope || ret.scope || ret.source || "customer",
      createdByName: ret.createdByName || "-",
      reason: ret.reason || "",
      note: ret.note || "",
      totalAmount: Number(ret.totalAmount || 0),
      createdAt: ret.createdAt ? new Date(ret.createdAt).toISOString() : null,
      items: Array.isArray(ret.items)
        ? ret.items.map(item => ({
            productName: item.productName || "-",
            qty: Number(item.qty || 0),
            unit: item.unit || "",
            price: Number(item.price || 0),
            lineTotal: Number(item.lineTotal || 0)
          }))
        : []
    }));

    const returnsJson = JSON.stringify(returnsForClient).replace(/</g, "\\u003c");
  %>

  <div class="wrapper">
    <div class="topbar">
      <h1 class="brand">Qaytimlar / Almashtirishlar</h1>

      <div class="topbar-right">
        <a href="/seller/sales" class="action-btn">Savdolar</a>

        <button type="button" class="menu-toggle" id="menuToggle" title="Bo‘limlar">
          <span class="menu-bars">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>

        <div class="menu-dropdown" id="menuDropdown">
          <div class="menu-title">Bo‘limlar</div>
          <div class="menu-links">
            <a href="/seller/dashboard">Kassa</a>
            <a href="/seller/sales">Savdolar</a>
            <a href="/seller/debts">Qarzlar</a>
            <a href="/seller/expenses">Chiqimlar</a>
            <a href="/seller/stock-entries">Kirimlar</a>
            <a href="/seller/returns">Qaytimlar</a>
            <a href="/auth/logout">Chiqish</a>
          </div>
        </div>
      </div>
    </div>

    <div class="summary-bar">
      <div class="summary-card">
        <div class="summary-label">Ko‘rinayotgan davr bo‘yicha qaytim</div>
        <div class="summary-value" id="visibleTotal">0</div>
        <div class="summary-sub" id="visiblePeriodText">Bugungi qaytimlar</div>
      </div>

      <div class="summary-card">
        <div class="summary-label">Jami yozuvlar soni</div>
        <div class="summary-value" id="visibleCount">0</div>
        <div class="summary-sub">Tanlangan davr bo‘yicha qaytim/almashtirishlar</div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-title">Pul qaytarishlar</div>
        <div class="stat-value red" id="refundTotal">0</div>
        <div class="stat-meta" id="refundCount">0 ta yozuv</div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Almashtirishlar</div>
        <div class="stat-value green" id="exchangeTotal">0</div>
        <div class="stat-meta" id="exchangeCount">0 ta yozuv</div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Mijoz qaytimlari</div>
        <div class="stat-value blue" id="customerReturnCount">0</div>
        <div class="stat-meta">Mijozdan olingan qaytimlar</div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Firma brak qaytimlari</div>
        <div class="stat-value yellow" id="supplierReturnCount">0</div>
        <div class="stat-meta">Firmaga bog‘liq qaytimlar</div>
      </div>
    </div>

    <div class="filters-panel">
      <div class="filters-top">
        <button class="period-btn active" data-period="today" type="button">Bugun</button>
        <button class="period-btn" data-period="week" type="button">Hafta</button>
        <button class="period-btn" data-period="month" type="button">Oy</button>
        <button class="period-btn" data-period="all" type="button">Barchasi</button>
      </div>

      <div class="filters-bottom">
        <div class="field">
          <label for="searchInput">Qidiruv</label>
          <input
            type="text"
            id="searchInput"
            placeholder="Mahsulot, sabab, izoh yoki kim kiritgani bo‘yicha qidiring..."
          />
        </div>

        <div class="field">
          <label for="typeSelect">Amal turi</label>
          <select id="typeSelect">
            <option value="all">Barcha turlar</option>
            <option value="refund">Pul qaytarish</option>
            <option value="exchange">Almashtirish</option>
          </select>
        </div>

        <div class="field">
          <label for="dateInput">Aniq sana</label>
          <input type="date" id="dateInput" />
        </div>

        <button class="clear-date-btn" type="button" id="clearDateBtn">Sanani tozalash</button>
      </div>
    </div>

    <div class="table-panel">
      <div class="table-headbar">
        <div>
          <h2>Qaytimlar tarixi</h2>
          <div class="sub" id="tableSub">Tanlangan davr bo‘yicha yozuvlar</div>
        </div>
      </div>

      <div class="returns-table-wrap">
        <div class="returns-table">
          <div class="returns-header">
            <div>Sana / vaqt</div>
            <div>Amal turi</div>
            <div>Manba</div>
            <div>Kim kiritdi</div>
            <div>Summa</div>
            <div>Amal</div>
          </div>

          <div id="returnRows"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="signature">SharqTech</div>

  <script>
    const ALL_RETURNS = <%- returnsJson %>;
    let activePeriod = "today";

    const searchInput = document.getElementById("searchInput");
    const typeSelect = document.getElementById("typeSelect");
    const dateInput = document.getElementById("dateInput");
    const clearDateBtn = document.getElementById("clearDateBtn");
    const periodButtons = Array.from(document.querySelectorAll(".period-btn"));
    const returnRows = document.getElementById("returnRows");

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("uz-UZ");
    }

    function formatDateTime(value) {
      const date = new Date(value);
      return date.toLocaleString("uz-UZ");
    }

    function normalizeReturnType(type) {
      const raw = String(type || "").toLowerCase().trim();
      if (raw === "exchange") return "exchange";
      return "refund";
    }

    function normalizeReturnScope(scope) {
      const raw = String(scope || "").toLowerCase().trim();
      if (
        raw.includes("supplier") ||
        raw.includes("firma") ||
        raw.includes("brak")
      ) return "supplier";
      return "customer";
    }

    function returnTypeLabel(type) {
      return normalizeReturnType(type) === "exchange" ? "Almashtirish" : "Pul qaytarish";
    }

    function returnScopeLabel(scope) {
      return normalizeReturnScope(scope) === "supplier" ? "Firma brak" : "Mijoz qaytimi";
    }

    function getTodayRange() {
      const now = new Date();
      const start = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const end = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
      return { start, end };
    }

    function getWeekRange() {
      const now = new Date();
      const day = now.getDay();
      const diff = day === 0 ? 6 : day - 1;
      const start = new Date(now.getFullYear(), now.getMonth(), now.getDate() - diff);
      start.setHours(0, 0, 0, 0);
      const end = new Date(start);
      end.setDate(start.getDate() + 7);
      return { start, end };
    }

    function getMonthRange() {
      const now = new Date();
      const start = new Date(now.getFullYear(), now.getMonth(), 1);
      const end = new Date(now.getFullYear(), now.getMonth() + 1, 1);
      return { start, end };
    }

    function getExactDateRange(dateValue) {
      const [year, month, day] = dateValue.split("-").map(Number);
      const start = new Date(year, month - 1, day);
      const end = new Date(year, month - 1, day + 1);
      return { start, end };
    }

    function getCurrentRange() {
      if (dateInput.value) {
        return {
          ...getExactDateRange(dateInput.value),
          label: "Tanlangan sana qaytimlari"
        };
      }

      if (activePeriod === "week") {
        return {
          ...getWeekRange(),
          label: "Haftalik qaytimlar"
        };
      }

      if (activePeriod === "month") {
        return {
          ...getMonthRange(),
          label: "Oylik qaytimlar"
        };
      }

      if (activePeriod === "all") {
        return {
          start: null,
          end: null,
          label: "Barcha qaytimlar"
        };
      }

      return {
        ...getTodayRange(),
        label: "Bugungi qaytimlar"
      };
    }

    function matchesPeriod(item) {
      if (!item.createdAt) return false;
      const { start, end } = getCurrentRange();
      if (!start || !end) return true;
      const created = new Date(item.createdAt);
      return created >= start && created < end;
    }

    function matchesType(item) {
      const selected = typeSelect.value || "all";
      if (selected === "all") return true;
      return normalizeReturnType(item.returnType) === selected;
    }

    function matchesSearch(item) {
      const query = (searchInput.value || "").toLowerCase().trim();
      if (!query) return true;

      const createdBy = String(item.createdByName || "").toLowerCase();
      const reason = String(item.reason || "").toLowerCase();
      const note = String(item.note || "").toLowerCase();
      const scope = returnScopeLabel(item.returnScope).toLowerCase();
      const type = returnTypeLabel(item.returnType).toLowerCase();
      const itemsText = (item.items || [])
        .map(x => `${x.productName || ""} ${x.unit || ""}`)
        .join(" ")
        .toLowerCase();

      return (
        createdBy.includes(query) ||
        reason.includes(query) ||
        note.includes(query) ||
        scope.includes(query) ||
        type.includes(query) ||
        itemsText.includes(query)
      );
    }

    function getFilteredReturns() {
      return ALL_RETURNS.filter(item =>
        matchesPeriod(item) &&
        matchesType(item) &&
        matchesSearch(item)
      );
    }

    function updateSummary(filtered) {
      const visibleTotal = filtered.reduce((sum, item) => sum + Number(item.totalAmount || 0), 0);

      let refundTotal = 0;
      let refundCount = 0;
      let exchangeTotal = 0;
      let exchangeCount = 0;
      let customerReturnCount = 0;
      let supplierReturnCount = 0;

      filtered.forEach(item => {
        const type = normalizeReturnType(item.returnType);
        const scope = normalizeReturnScope(item.returnScope);
        const amount = Number(item.totalAmount || 0);

        if (type === "refund") {
          refundTotal += amount;
          refundCount += 1;
        } else {
          exchangeTotal += amount;
          exchangeCount += 1;
        }

        if (scope === "supplier") {
          supplierReturnCount += 1;
        } else {
          customerReturnCount += 1;
        }
      });

      document.getElementById("visibleTotal").textContent = formatMoney(visibleTotal);
      document.getElementById("visibleCount").textContent = filtered.length;
      document.getElementById("visiblePeriodText").textContent = getCurrentRange().label;
      document.getElementById("tableSub").textContent = getCurrentRange().label;

      document.getElementById("refundTotal").textContent = formatMoney(refundTotal);
      document.getElementById("refundCount").textContent = `${refundCount} ta yozuv`;

      document.getElementById("exchangeTotal").textContent = formatMoney(exchangeTotal);
      document.getElementById("exchangeCount").textContent = `${exchangeCount} ta yozuv`;

      document.getElementById("customerReturnCount").textContent = customerReturnCount;
      document.getElementById("supplierReturnCount").textContent = supplierReturnCount;
    }

    function buildDetailsHTML(item) {
      const itemsHTML = (item.items || []).length
        ? item.items.map(product => `
            <div class="item-card">
              <strong>${product.productName || "-"}</strong>
              ${Number(product.qty || 0)} ${product.unit || ""} × ${formatMoney(product.price || 0)}
              = ${formatMoney(product.lineTotal || 0)}
            </div>
          `).join("")
        : `<div class="item-card">Mahsulot ma’lumoti yo‘q.</div>`;

      return `
        <div class="details-box">
          <div class="details-top">
            <div><strong>Turi:</strong> ${returnTypeLabel(item.returnType)}</div>
            <div><strong>Manba:</strong> ${returnScopeLabel(item.returnScope)}</div>
            <div><strong>Kim kiritdi:</strong> ${item.createdByName || "-"}</div>
            <div><strong>Sana:</strong> ${item.createdAt ? formatDateTime(item.createdAt) : "-"}</div>
          </div>

          ${
            item.reason
              ? `<div class="note-box"><strong>Sabab:</strong><br>${item.reason}</div>`
              : ""
          }

          <div class="items-grid">${itemsHTML}</div>

          <div class="note-box">
            <strong>Izoh:</strong><br>
            ${item.note ? item.note : "Izoh kiritilmagan."}
          </div>
        </div>
      `;
    }

    function renderReturns(filtered) {
      if (!filtered.length) {
        returnRows.innerHTML = `
          <div class="empty-box">
            Tanlangan filter bo‘yicha qaytimlar topilmadi.
          </div>
        `;
        return;
      }

      const sorted = filtered.slice().sort((a, b) => {
        return new Date(b.createdAt || 0) - new Date(a.createdAt || 0);
      });

      returnRows.innerHTML = sorted.map(item => {
        const detailsId = `details-${item._id}`;
        const type = normalizeReturnType(item.returnType);
        const scope = normalizeReturnScope(item.returnScope);

        return `
          <div class="return-item">
            <div class="returns-row">
              <div class="returns-cell">${item.createdAt ? formatDateTime(item.createdAt) : "-"}</div>

              <div class="returns-cell">
                <span class="type-badge ${type === "exchange" ? "type-exchange" : "type-refund"}">
                  ${returnTypeLabel(item.returnType)}
                </span>
              </div>

              <div class="returns-cell">
                <span class="scope-badge ${scope === "supplier" ? "scope-supplier" : "scope-customer"}">
                  ${returnScopeLabel(item.returnScope)}
                </span>
              </div>

              <div class="returns-cell">${item.createdByName || "-"}</div>

              <div class="sum-cell">${formatMoney(item.totalAmount || 0)}</div>

              <div class="returns-cell">
                <button class="view-btn" type="button" onclick="toggleDetails('${detailsId}')">Ko‘rish</button>
              </div>
            </div>

            <div class="return-details" id="${detailsId}">
              ${buildDetailsHTML(item)}
            </div>
          </div>
        `;
      }).join("");
    }

    function renderAll() {
      const filtered = getFilteredReturns();
      updateSummary(filtered);
      renderReturns(filtered);
    }

    function toggleDetails(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.toggle("open");
    }

    periodButtons.forEach(button => {
      button.addEventListener("click", function () {
        periodButtons.forEach(btn => btn.classList.remove("active"));
        this.classList.add("active");
        activePeriod = this.dataset.period || "today";
        dateInput.value = "";
        renderAll();
      });
    });

    searchInput.addEventListener("input", renderAll);
    typeSelect.addEventListener("change", renderAll);

    dateInput.addEventListener("change", function () {
      if (dateInput.value) {
        periodButtons.forEach(btn => btn.classList.remove("active"));
      } else {
        const currentActive = periodButtons.find(btn => btn.dataset.period === activePeriod);
        if (currentActive) currentActive.classList.add("active");
      }
      renderAll();
    });

    clearDateBtn.addEventListener("click", function () {
      dateInput.value = "";
      periodButtons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.period === activePeriod);
      });
      renderAll();
    });

    const menuToggle = document.getElementById("menuToggle");
    const menuDropdown = document.getElementById("menuDropdown");

    if (menuToggle && menuDropdown) {
      menuToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        menuDropdown.classList.toggle("open");
      });

      menuDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });

      document.addEventListener("click", function () {
        menuDropdown.classList.remove("open");
      });
    }

    renderAll();
  </script>
</body>
</html>
