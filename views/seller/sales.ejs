<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Savdolar</title>

  <style>
    :root {
      --bg: #06111f;
      --panel: #0d1c33;
      --panel-2: #09162b;
      --line: rgba(255, 255, 255, 0.08);
      --line-soft: rgba(255, 255, 255, 0.05);
      --text: #eef4ff;
      --muted: #8ea4c7;
      --accent: #fbbf24;
      --accent-2: #ffd15f;
      --green: #22c55e;
      --blue: #3b82f6;
      --red: #ef4444;
      --shadow: 0 14px 38px rgba(0, 0, 0, 0.28);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 24%),
        var(--bg);
      color: var(--text);
    }

    body {
      padding: 10px 12px 30px;
    }

    .wrapper {
      max-width: 1680px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      min-height: 50px;
    }

    .brand {
      margin: 0;
      font-size: 30px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.8px;
      color: var(--accent);
    }

    .topbar-right {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .menu-toggle {
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #182c4b, #12213a);
      color: white;
      border-radius: 14px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.18s ease;
      box-shadow: var(--shadow);
      padding: 0;
    }

    .menu-toggle:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.22);
    }

    .menu-bars {
      width: 18px;
      height: 14px;
      display: grid;
      gap: 4px;
    }

    .menu-bars span {
      display: block;
      height: 2px;
      background: #fff;
      border-radius: 999px;
    }

    .menu-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      width: 270px;
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 10px;
      display: none;
      z-index: 100;
    }

    .menu-dropdown.open {
      display: block;
      animation: fadeDown 0.18s ease;
    }

    @keyframes fadeDown {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .menu-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      margin: 4px 6px 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .menu-links {
      display: grid;
      gap: 8px;
    }

    .menu-links a {
      text-decoration: none;
      color: white;
      background: linear-gradient(180deg, #142540, #102038);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      transition: 0.18s ease;
    }

    .menu-links a:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, #1a2f50, #152741);
      border-color: rgba(251,191,36,0.20);
    }

    .summary-bar {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 10px;
    }

    .summary-card {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 16px 18px;
    }

    .summary-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    .summary-value {
      font-size: 30px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.05;
      word-break: break-word;
    }

    .summary-sub {
      margin-top: 6px;
      color: var(--muted);
      font-size: 13px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .stat-card {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 14px 16px;
    }

    .stat-title {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 26px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 6px;
      color: white;
    }

    .stat-value.cash { color: var(--green); }
    .stat-value.card { color: #93c5fd; }
    .stat-value.debt { color: #fca5a5; }
    .stat-value.transfer { color: var(--accent); }

    .stat-meta {
      color: var(--muted);
      font-size: 12px;
    }

    .filters-panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 14px;
      display: grid;
      gap: 12px;
    }

    .filters-top {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .period-btn {
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #dce8fb;
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .period-btn.active {
      background: linear-gradient(180deg, var(--accent), #f0b61d);
      color: #101722;
      border-color: rgba(251,191,36,0.22);
    }

    .filters-bottom {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) 220px 160px;
      gap: 10px;
      align-items: end;
    }

    .field {
      display: grid;
      gap: 6px;
    }

    .field label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 700;
    }

    .field input,
    .field select {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 14px;
      outline: none;
    }

    .field input:focus,
    .field select:focus {
      border-color: rgba(59,130,246,0.42);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .clear-date-btn {
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #dce8fb;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
      height: 44px;
    }

    .clear-date-btn:hover {
      border-color: rgba(251,191,36,0.20);
    }

    .table-panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .table-headbar {
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .table-headbar h2 {
      margin: 0;
      color: var(--accent);
      font-size: 20px;
    }

    .table-headbar .sub {
      color: var(--muted);
      font-size: 12px;
    }

    .sales-table-wrap {
      padding: 12px 14px 14px;
      overflow-x: auto;
    }

    .sales-table {
      min-width: 920px;
      display: grid;
      gap: 8px;
    }

    .sales-row,
    .sales-header {
      display: grid;
      grid-template-columns: 170px 150px 130px 160px 140px 90px;
      gap: 8px;
      align-items: center;
      border-radius: 14px;
    }

    .sales-header {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      padding: 10px 12px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .sales-item {
      background: linear-gradient(180deg, #0d1b33, #0a162b);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      overflow: hidden;
    }

    .sales-row {
      padding: 10px 12px;
    }

    .sales-cell {
      font-size: 13px;
      color: white;
      line-height: 1.25;
      word-break: break-word;
    }

    .sales-cell strong {
      font-size: 14px;
    }

    .payment-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 88px;
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #dce8fb;
    }

    .payment-badge.cash {
      background: rgba(34,197,94,0.12);
      color: #86efac;
      border-color: rgba(34,197,94,0.18);
    }

    .payment-badge.card {
      background: rgba(59,130,246,0.12);
      color: #93c5fd;
      border-color: rgba(59,130,246,0.18);
    }

    .payment-badge.debt {
      background: rgba(239,68,68,0.12);
      color: #fca5a5;
      border-color: rgba(239,68,68,0.18);
    }

    .payment-badge.transfer {
      background: rgba(251,191,36,0.12);
      color: var(--accent);
      border-color: rgba(251,191,36,0.18);
    }

    .sum-cell {
      color: var(--accent);
      font-size: 18px;
      font-weight: 800;
      text-align: right;
    }

    .view-btn {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #233754, #1a2c46);
      color: white;
      border-radius: 10px;
      padding: 9px 10px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .view-btn:hover {
      transform: translateY(-1px);
    }

    .sale-details {
      display: none;
      padding: 0 12px 12px;
    }

    .sale-details.open {
      display: block;
    }

    .details-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 12px;
      display: grid;
      gap: 8px;
    }

    .details-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 12px;
    }

    .items-grid {
      display: grid;
      gap: 8px;
    }

    .item-card {
      background: #0b1730;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px 12px;
      color: white;
      font-size: 13px;
      line-height: 1.35;
    }

    .item-card strong {
      display: block;
      margin-bottom: 4px;
      font-size: 14px;
    }

    .details-total {
      display: flex;
      justify-content: flex-end;
      gap: 20px;
      flex-wrap: wrap;
      color: white;
      font-size: 13px;
      font-weight: 700;
    }

    .details-total .accent {
      color: var(--accent);
    }

    .empty-box {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px dashed rgba(255,255,255,0.10);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 24px;
      color: var(--muted);
      text-align: center;
      font-size: 14px;
    }

    .signature {
      position: fixed;
      right: 16px;
      bottom: 8px;
      color: rgba(255,255,255,0.35);
      font-size: 12px;
      letter-spacing: 0.5px;
      user-select: none;
      pointer-events: none;
    }

    @media (max-width: 980px) {
      .summary-bar,
      .stats-grid,
      .filters-bottom {
        grid-template-columns: 1fr;
      }

      .summary-value {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeSales = Array.isArray(sales) ? sales : [];

    const salesForClient = safeSales.map(sale => ({
      _id: String(sale._id || ""),
      sellerName: sale.sellerName || "-",
      paymentType: String(sale.paymentType || "").toLowerCase(),
      totalAmount: Number(sale.finalTotal || sale.totalAmount || 0),
      subtotalAmount: Number(sale.subtotalAmount || sale.totalAmount || 0),
      discountAmount: Number(sale.discountAmount || 0),
      note: sale.note || "",
      createdAt: sale.createdAt ? new Date(sale.createdAt).toISOString() : null,
      items: Array.isArray(sale.items)
        ? sale.items.map(item => ({
            productName: item.productName || "-",
            qty: Number(item.qty || 0),
            unit: item.unit || "",
            price: Number(item.price || 0),
            lineTotal: Number(item.lineTotal || 0)
          }))
        : []
    }));

    const salesJson = JSON.stringify(salesForClient).replace(/</g, "\\u003c");
  %>

  <div class="wrapper">
    <div class="topbar">
      <h1 class="brand">Savdolar</h1>

      <div class="topbar-right">
        <button type="button" class="menu-toggle" id="menuToggle" title="Bo‘limlar">
          <span class="menu-bars">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>

        <div class="menu-dropdown" id="menuDropdown">
          <div class="menu-title">Bo‘limlar</div>
          <div class="menu-links">
            <a href="/seller/dashboard">Kassa</a>
            <a href="/seller/sales">Savdolar</a>
            <a href="/seller/debts">Qarzlar</a>
            <a href="/seller/expenses">Chiqimlar</a>
            <a href="/seller/stock-entries">Kirimlar</a>
            <a href="/seller/suppliers">Firmalar</a>
            <a href="/seller/supplier-payments">Firma to‘lovlari</a>
            <a href="/auth/logout">Chiqish</a>
          </div>
        </div>
      </div>
    </div>

    <div class="summary-bar">
      <div class="summary-card">
        <div class="summary-label">Ko‘rinayotgan davr</div>
        <div class="summary-value" id="visibleTotal">0</div>
        <div class="summary-sub" id="visiblePeriodText">Bugungi savdolar</div>
      </div>

      <div class="summary-card">
        <div class="summary-label">Jami savdolar soni</div>
        <div class="summary-value" id="visibleCount">0</div>
        <div class="summary-sub">Tanlangan davr bo‘yicha yozuvlar</div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-title">Naqd savdo</div>
        <div class="stat-value cash" id="cashTotal">0</div>
        <div class="stat-meta" id="cashCount">0 ta savdo</div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Karta savdo</div>
        <div class="stat-value card" id="cardTotal">0</div>
        <div class="stat-meta" id="cardCount">0 ta savdo</div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Nasiya savdo</div>
        <div class="stat-value debt" id="debtTotal">0</div>
        <div class="stat-meta" id="debtCount">0 ta savdo</div>
      </div>

      <div class="stat-card">
        <div class="stat-title">O‘tkazma savdo</div>
        <div class="stat-value transfer" id="transferTotal">0</div>
        <div class="stat-meta" id="transferCount">0 ta savdo</div>
      </div>
    </div>

    <div class="filters-panel">
      <div class="filters-top">
        <button class="period-btn active" data-period="today" type="button">Bugun</button>
        <button class="period-btn" data-period="week" type="button">Hafta</button>
        <button class="period-btn" data-period="month" type="button">Oy</button>
      </div>

      <div class="filters-bottom">
        <div class="field">
          <label for="searchInput">Qidiruv</label>
          <input
            type="text"
            id="searchInput"
            placeholder="Sotuvchi, mahsulot yoki to‘lov turi bo‘yicha qidiring..."
          />
        </div>

        <div class="field">
          <label for="dateInput">Aniq sana</label>
          <input type="date" id="dateInput" />
        </div>

        <button class="clear-date-btn" type="button" id="clearDateBtn">Sanani tozalash</button>
      </div>
    </div>

    <div class="table-panel">
      <div class="table-headbar">
        <div>
          <h2>Savdo tarixi</h2>
          <div class="sub" id="tableSub">Tanlangan davr bo‘yicha savdolar</div>
        </div>
      </div>

      <div class="sales-table-wrap">
        <div class="sales-table" id="salesTable">
          <div class="sales-header">
            <div>Sana / vaqt</div>
            <div>Sotuvchi</div>
            <div>To‘lov turi</div>
            <div>Mahsulotlar</div>
            <div>Jami summa</div>
            <div>Amal</div>
          </div>

          <div id="salesRows"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="signature">SharqTech</div>

  <script>
    const ALL_SALES = <%- salesJson %>;
    let activePeriod = "today";

    const searchInput = document.getElementById("searchInput");
    const dateInput = document.getElementById("dateInput");
    const clearDateBtn = document.getElementById("clearDateBtn");
    const periodButtons = Array.from(document.querySelectorAll(".period-btn"));
    const salesRows = document.getElementById("salesRows");

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("uz-UZ");
    }

    function formatDateTime(value) {
      const date = new Date(value);
      return date.toLocaleString("uz-UZ");
    }

    function normalizePaymentType(type) {
      const raw = String(type || "").toLowerCase().trim();

      if (
        raw === "cash" ||
        raw === "naqd" ||
        raw.includes("naqd")
      ) return "cash";

      if (
        raw === "card" ||
        raw.includes("plastik") ||
        raw.includes("karta") ||
        raw.includes("card")
      ) return "card";

      if (
        raw === "debt" ||
        raw.includes("nasiya") ||
        raw.includes("qarz")
      ) return "debt";

      if (
        raw === "transfer" ||
        raw.includes("o'tkazma") ||
        raw.includes("otkazma") ||
        raw.includes("transfer")
      ) return "transfer";

      return raw || "other";
    }

    function paymentLabel(type) {
      const normalized = normalizePaymentType(type);

      if (normalized === "cash") return "Naqd";
      if (normalized === "card") return "Karta";
      if (normalized === "debt") return "Nasiya";
      if (normalized === "transfer") return "O‘tkazma";
      return type || "-";
    }

    function getTodayRange() {
      const now = new Date();
      const start = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const end = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
      return { start, end };
    }

    function getWeekRange() {
      const now = new Date();
      const day = now.getDay();
      const diff = day === 0 ? 6 : day - 1;
      const start = new Date(now.getFullYear(), now.getMonth(), now.getDate() - diff);
      start.setHours(0, 0, 0, 0);
      const end = new Date(start);
      end.setDate(start.getDate() + 7);
      return { start, end };
    }

    function getMonthRange() {
      const now = new Date();
      const start = new Date(now.getFullYear(), now.getMonth(), 1);
      const end = new Date(now.getFullYear(), now.getMonth() + 1, 1);
      return { start, end };
    }

    function getExactDateRange(dateValue) {
      const [year, month, day] = dateValue.split("-").map(Number);
      const start = new Date(year, month - 1, day);
      const end = new Date(year, month - 1, day + 1);
      return { start, end };
    }

    function getCurrentRange() {
      if (dateInput.value) {
        return {
          ...getExactDateRange(dateInput.value),
          label: "Tanlangan sana"
        };
      }

      if (activePeriod === "week") {
        return {
          ...getWeekRange(),
          label: "Haftalik savdolar"
        };
      }

      if (activePeriod === "month") {
        return {
          ...getMonthRange(),
          label: "Oylik savdolar"
        };
      }

      return {
        ...getTodayRange(),
        label: "Bugungi savdolar"
      };
    }

    function matchesPeriod(sale) {
      if (!sale.createdAt) return false;
      const { start, end } = getCurrentRange();
      const created = new Date(sale.createdAt);
      return created >= start && created < end;
    }

    function matchesSearch(sale) {
      const query = (searchInput.value || "").toLowerCase().trim();
      if (!query) return true;

      const seller = String(sale.sellerName || "").toLowerCase();
      const payment = paymentLabel(sale.paymentType).toLowerCase();
      const dateText = sale.createdAt ? formatDateTime(sale.createdAt).toLowerCase() : "";
      const itemsText = (sale.items || [])
        .map(item => `${item.productName || ""} ${item.unit || ""}`)
        .join(" ")
        .toLowerCase();

      return (
        seller.includes(query) ||
        payment.includes(query) ||
        dateText.includes(query) ||
        itemsText.includes(query)
      );
    }

    function getFilteredSales() {
      return ALL_SALES.filter(sale => matchesPeriod(sale) && matchesSearch(sale));
    }

    function updateSummary(filteredSales) {
      const totals = {
        cash: 0,
        card: 0,
        debt: 0,
        transfer: 0
      };

      const counts = {
        cash: 0,
        card: 0,
        debt: 0,
        transfer: 0
      };

      let visibleTotal = 0;

      filteredSales.forEach(sale => {
        const type = normalizePaymentType(sale.paymentType);
        const amount = Number(sale.totalAmount || 0);
        visibleTotal += amount;

        if (Object.prototype.hasOwnProperty.call(totals, type)) {
          totals[type] += amount;
          counts[type] += 1;
        }
      });

      document.getElementById("visibleTotal").textContent = formatMoney(visibleTotal);
      document.getElementById("visibleCount").textContent = filteredSales.length;
      document.getElementById("visiblePeriodText").textContent = getCurrentRange().label;
      document.getElementById("tableSub").textContent = getCurrentRange().label;

      document.getElementById("cashTotal").textContent = formatMoney(totals.cash);
      document.getElementById("cardTotal").textContent = formatMoney(totals.card);
      document.getElementById("debtTotal").textContent = formatMoney(totals.debt);
      document.getElementById("transferTotal").textContent = formatMoney(totals.transfer);

      document.getElementById("cashCount").textContent = `${counts.cash} ta savdo`;
      document.getElementById("cardCount").textContent = `${counts.card} ta savdo`;
      document.getElementById("debtCount").textContent = `${counts.debt} ta savdo`;
      document.getElementById("transferCount").textContent = `${counts.transfer} ta savdo`;
    }

    function buildDetailsHTML(sale) {
      const itemsHTML = (sale.items || []).map(item => `
        <div class="item-card">
          <strong>${item.productName || "-"}</strong>
          ${Number(item.qty || 0)} ${item.unit || ""} × ${formatMoney(item.price || 0)}
          = ${formatMoney(item.lineTotal || 0)}
        </div>
      `).join("");

      return `
        <div class="details-box">
          <div class="details-top">
            <div><strong>Sotuvchi:</strong> ${sale.sellerName || "-"}</div>
            <div><strong>To‘lov turi:</strong> ${paymentLabel(sale.paymentType)}</div>
            <div><strong>Sana:</strong> ${sale.createdAt ? formatDateTime(sale.createdAt) : "-"}</div>
          </div>

          <div class="items-grid">
            ${itemsHTML || '<div class="item-card">Mahsulot ma’lumoti yo‘q.</div>'}
          </div>

          <div class="details-total">
            <div>Mahsulotlar jami: ${formatMoney(sale.subtotalAmount || sale.totalAmount || 0)}</div>
            <div>O‘tib berilgan: ${formatMoney(sale.discountAmount || 0)}</div>
            <div class="accent">Yakuniy summa: ${formatMoney(sale.totalAmount || 0)}</div>
          </div>
        </div>
      `;
    }

    function renderSales(filteredSales) {
      if (!filteredSales.length) {
        salesRows.innerHTML = `
          <div class="empty-box">
            Tanlangan davr bo‘yicha savdolar topilmadi.
          </div>
        `;
        return;
      }

      salesRows.innerHTML = filteredSales.map(sale => {
        const itemCount = Array.isArray(sale.items) ? sale.items.length : 0;
        const paymentType = normalizePaymentType(sale.paymentType);
        const detailsId = `details-${sale._id}`;

        return `
          <div class="sales-item">
            <div class="sales-row">
              <div class="sales-cell">${sale.createdAt ? formatDateTime(sale.createdAt) : "-"}</div>
              <div class="sales-cell"><strong>${sale.sellerName || "-"}</strong></div>
              <div class="sales-cell">
                <span class="payment-badge ${paymentType}">${paymentLabel(sale.paymentType)}</span>
              </div>
              <div class="sales-cell">${itemCount} ta mahsulot</div>
              <div class="sum-cell">${formatMoney(sale.totalAmount || 0)}</div>
              <div class="sales-cell">
                <button class="view-btn" type="button" onclick="toggleDetails('${detailsId}')">
                  Ko‘rish
                </button>
              </div>
            </div>

            <div class="sale-details" id="${detailsId}">
              ${buildDetailsHTML(sale)}
            </div>
          </div>
        `;
      }).join("");
    }

    function renderAll() {
      const filteredSales = getFilteredSales();
      updateSummary(filteredSales);
      renderSales(filteredSales);
    }

    function toggleDetails(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.toggle("open");
    }

    periodButtons.forEach(button => {
      button.addEventListener("click", function () {
        periodButtons.forEach(btn => btn.classList.remove("active"));
        this.classList.add("active");
        activePeriod = this.dataset.period || "today";
        dateInput.value = "";
        renderAll();
      });
    });

    searchInput.addEventListener("input", renderAll);

    dateInput.addEventListener("change", function () {
      if (dateInput.value) {
        periodButtons.forEach(btn => btn.classList.remove("active"));
      } else {
        const currentActive = periodButtons.find(btn => btn.dataset.period === activePeriod);
        if (currentActive) currentActive.classList.add("active");
      }
      renderAll();
    });

    clearDateBtn.addEventListener("click", function () {
      dateInput.value = "";
      periodButtons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.period === activePeriod);
      });
      renderAll();
    });

    const menuToggle = document.getElementById("menuToggle");
    const menuDropdown = document.getElementById("menuDropdown");

    if (menuToggle && menuDropdown) {
      menuToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        menuDropdown.classList.toggle("open");
      });

      menuDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });

      document.addEventListener("click", function () {
        menuDropdown.classList.remove("open");
      });
    }

    setInterval(() => {
      if (!dateInput.value) {
        renderAll();
      }
    }, 60000);

    renderAll();
  </script>
</body>
</html>
