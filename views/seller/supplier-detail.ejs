<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Firma tarixi</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    .wrapper {
      max-width: 1150px;
      margin: 0 auto;
      padding: 20px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    h1 {
      margin: 0;
      color: #fbbf24;
    }

    .actions a {
      text-decoration: none;
      background: #1e293b;
      color: white;
      padding: 10px 14px;
      border-radius: 10px;
      display: inline-block;
      margin-left: 8px;
    }

    .info-card,
    .section {
      background: #1e293b;
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 18px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .stat-box {
      background: #0f172a;
      border-radius: 14px;
      padding: 14px;
    }

    .stat-title {
      font-size: 14px;
      opacity: 0.9;
      margin-bottom: 6px;
    }

    .stat-value {
      font-size: 24px;
      font-weight: bold;
      color: #fbbf24;
    }

    .section h2 {
      margin-top: 0;
      color: #fbbf24;
    }

    .entry-card,
    .payment-card {
      background: #0f172a;
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 10px;
    }

    .item {
      background: rgba(255,255,255,0.04);
      padding: 10px;
      border-radius: 10px;
      margin-top: 8px;
    }

    .empty {
      background: #0f172a;
      padding: 14px;
      border-radius: 12px;
      opacity: 0.9;
    }

    @media (max-width: 900px) {
      .info-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="topbar">
      <h1>Firma tarixi</h1>
      <div class="actions">
        <a href="/seller/suppliers">Firmalar</a>
        <a href="/seller/stock-entries/new">Yangi kirim</a>
        <a href="/seller/supplier-payments/new">To‘lov qo‘shish</a>
      </div>
    </div>

    <div class="info-card">
      <h2><%= supplier.name %></h2>
      <div style="margin-bottom:8px;">Telefon: <%= supplier.phone || "-" %></div>
      <div style="margin-bottom:8px;">Manzil: <%= supplier.address || "-" %></div>
      <div style="margin-bottom:12px;">Izoh: <%= supplier.note || "-" %></div>

      <div class="info-grid">
        <div class="stat-box">
          <div class="stat-title">Joriy qarz</div>
          <div class="stat-value"><%= Number(supplier.totalDebt || 0).toLocaleString("uz-UZ") %></div>
        </div>

        <div class="stat-box">
          <div class="stat-title">Jami kirim summasi</div>
          <div class="stat-value"><%= Number(totalEntryAmount || 0).toLocaleString("uz-UZ") %></div>
        </div>

        <div class="stat-box">
          <div class="stat-title">Jami to‘lov summasi</div>
          <div class="stat-value"><%= Number(totalPaidAmount || 0).toLocaleString("uz-UZ") %></div>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Kirimlar tarixi</h2>

      <% if (!stockEntries || stockEntries.length === 0) { %>
        <div class="empty">Bu firma bo‘yicha hali kirimlar yo‘q.</div>
      <% } else { %>
        <% stockEntries.forEach(entry => { %>
          <div class="entry-card">
            <div><strong>Sana:</strong> <%= new Date(entry.createdAt).toLocaleString("uz-UZ") %></div>
            <div><strong>To‘lov holati:</strong> <%= entry.paymentStatus %></div>
            <div><strong>Jami:</strong> <%= Number(entry.totalAmount || 0).toLocaleString("uz-UZ") %></div>

            <% if (entry.paymentStatus === "debt") { %>
              <div><strong>To‘langan:</strong> <%= Number(entry.paidAmount || 0).toLocaleString("uz-UZ") %></div>
              <div><strong>Qolgan:</strong> <%= Number(entry.remainingAmount || 0).toLocaleString("uz-UZ") %></div>
            <% } %>

            <% entry.items.forEach(item => { %>
              <div class="item">
                <strong><%= item.productName %></strong><br/>
                <%= item.qty %> × <%= Number(item.purchasePrice || 0).toLocaleString("uz-UZ") %>
                = <%= Number(item.lineTotal || 0).toLocaleString("uz-UZ") %>
              </div>
            <% }) %>

            <% if (entry.note) { %>
              <div style="margin-top:8px;">Izoh: <%= entry.note %></div>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div class="section">
      <h2>To‘lovlar tarixi</h2>

      <% if (!payments || payments.length === 0) { %>
        <div class="empty">Bu firma bo‘yicha hali to‘lovlar yo‘q.</div>
      <% } else { %>
        <% payments.forEach(payment => { %>
          <div class="payment-card">
            <div><strong>Sana:</strong> <%= new Date(payment.createdAt).toLocaleString("uz-UZ") %></div>
            <div><strong>Summa:</strong> <%= Number(payment.amount || 0).toLocaleString("uz-UZ") %></div>
            <div><strong>Kim kiritdi:</strong> <%= payment.createdByName || "-" %></div>

            <% if (payment.note) { %>
              <div style="margin-top:8px;">Izoh: <%= payment.note %></div>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>