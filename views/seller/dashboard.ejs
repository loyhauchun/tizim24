<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sotuvchi paneli</title>

  <style>
    :root {
      --bg: #06111f;
      --panel: #0d1c33;
      --panel-2: #09162b;
      --panel-3: #132541;
      --line: rgba(255, 255, 255, 0.08);
      --line-soft: rgba(255, 255, 255, 0.05);
      --text: #eef4ff;
      --muted: #8ea4c7;
      --accent: #fbbf24;
      --accent-2: #ffd15f;
      --green: #22c55e;
      --green-2: #16a34a;
      --red: #ef4444;
      --red-2: #dc2626;
      --blue: #3b82f6;
      --shadow: 0 14px 38px rgba(0, 0, 0, 0.28);
      --radius: 18px;
      --radius-sm: 12px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow: hidden;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 24%),
        var(--bg);
      color: var(--text);
    }

    body {
      min-height: 100vh;
    }

    .wrapper {
      max-width: 1540px;
      margin: 0 auto;
      height: 100vh;
      padding: 12px 16px 34px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      overflow: hidden;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      min-height: 66px;
    }

    .brand-wrap {
      min-width: 290px;
    }

    .brand {
      margin: 0;
      font-size: 36px;
      line-height: 1.02;
      font-weight: 800;
      letter-spacing: -0.8px;
      color: var(--accent);
    }

    .brand-sub {
      margin-top: 6px;
      color: var(--muted);
      font-size: 14px;
      white-space: nowrap;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
      position: relative;
    }

    .today-badge {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(251,191,36,0.10);
      border: 1px solid rgba(251,191,36,0.18);
      color: var(--accent);
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .menu-toggle {
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #182c4b, #12213a);
      color: white;
      padding: 11px 15px;
      border-radius: 14px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 9px;
      transition: 0.18s ease;
      box-shadow: var(--shadow);
    }

    .menu-toggle:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.22);
    }

    .menu-bars {
      width: 16px;
      height: 12px;
      display: grid;
      gap: 3px;
    }

    .menu-bars span {
      display: block;
      height: 2px;
      background: #fff;
      border-radius: 999px;
    }

    .menu-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      width: 270px;
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 10px;
      display: none;
      z-index: 60;
    }

    .menu-dropdown.open {
      display: block;
      animation: fadeDown 0.18s ease;
    }

    @keyframes fadeDown {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .menu-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      margin: 4px 6px 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .menu-links {
      display: grid;
      gap: 8px;
    }

    .menu-links a {
      text-decoration: none;
      color: white;
      background: linear-gradient(180deg, #142540, #102038);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 11px 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      transition: 0.18s ease;
    }

    .menu-links a:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, #1a2f50, #152741);
      border-color: rgba(251,191,36,0.20);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      min-height: 86px;
    }

    .stat-card {
      background: linear-gradient(180deg, rgba(19,37,65,0.96), rgba(12,24,46,0.96));
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 13px 15px;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 86px;
    }

    .stat-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 24px;
      font-weight: 800;
      line-height: 1;
      color: white;
      word-break: break-word;
    }

    .stat-value.gold {
      color: var(--accent);
    }

    .stat-value.green {
      color: #86efac;
    }

    .workspace {
      flex: 1;
      min-height: 0;
      display: grid;
      grid-template-columns: minmax(0, 1.85fr) minmax(375px, 0.9fr);
      gap: 12px;
      overflow: hidden;
    }

    .left-column,
    .right-column {
      min-height: 0;
      overflow: hidden;
    }

    .panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .products-panel {
      height: 100%;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .panel-head {
      padding: 15px 16px 8px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .panel-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 24px;
      line-height: 1.04;
    }

    .panel-sub {
      margin-top: 4px;
      color: var(--muted);
      font-size: 13px;
    }

    .search-row {
      padding: 0 16px 10px;
    }

    .search-input,
    .select-input,
    .text-input,
    .note-input {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 15px;
      outline: none;
    }

    .search-input:focus,
    .select-input:focus,
    .text-input:focus,
    .note-input:focus {
      border-color: rgba(59,130,246,0.42);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .category-strip {
      padding: 0 16px 10px;
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: thin;
    }

    .category-strip::-webkit-scrollbar {
      height: 6px;
    }

    .category-strip::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .category-chip {
      flex: 0 0 auto;
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #d7e7ff;
      border-radius: 999px;
      padding: 9px 14px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
      white-space: nowrap;
    }

    .category-chip:hover {
      background: #182c4c;
    }

    .category-chip.active {
      background: linear-gradient(180deg, var(--accent), #f1b61e);
      color: #131923;
      border-color: rgba(251,191,36,0.24);
    }

    .products-body {
      flex: 1;
      min-height: 0;
      padding: 0 16px 16px;
      overflow: hidden;
    }

    .products-grid {
      height: 100%;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(245px, 1fr));
      gap: 12px;
      overflow-y: auto;
      padding-right: 4px;
      align-content: start;
    }

    .products-grid::-webkit-scrollbar {
      width: 8px;
    }

    .products-grid::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .product-card {
      background: linear-gradient(180deg, #0b1831, #081528);
      border: 1px solid var(--line-soft);
      border-radius: 18px;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 238px;
      transition: 0.18s ease;
    }

    .product-card:hover {
      transform: translateY(-2px);
      border-color: rgba(251,191,36,0.20);
    }

    .product-top {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: flex-start;
    }

    .product-name {
      font-size: 16px;
      font-weight: 800;
      line-height: 1.2;
      color: white;
      word-break: break-word;
    }

    .unit-badge {
      background: rgba(251,191,36,0.12);
      color: var(--accent);
      border: 1px solid rgba(251,191,36,0.18);
      border-radius: 999px;
      padding: 6px 10px;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .meta-box {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 12px;
      padding: 9px 10px;
    }

    .meta-label {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .meta-value {
      font-size: 14px;
      font-weight: 700;
      color: white;
      line-height: 1.2;
      word-break: break-word;
    }

    .inputs-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: auto;
    }

    .product-card .text-input {
      padding: 11px 12px;
      font-size: 14px;
    }

    .add-btn {
      width: 100%;
      border: none;
      border-radius: 14px;
      padding: 11px 12px;
      background: linear-gradient(180deg, var(--accent), #f2b41a);
      color: #121826;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .add-btn:hover {
      background: linear-gradient(180deg, var(--accent-2), #edb31d);
      transform: translateY(-1px);
    }

    .cart-panel {
      height: 100%;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .cart-head {
      padding: 16px 16px 10px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }

    .cart-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 24px;
    }

    .cart-count {
      background: rgba(34,197,94,0.12);
      color: #9ff0b8;
      border: 1px solid rgba(34,197,94,0.18);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .cart-body {
      flex: 1;
      min-height: 0;
      padding: 0 16px 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      overflow: hidden;
    }

    .cart-list {
      min-height: 120px;
      max-height: 225px;
      overflow-y: auto;
      display: grid;
      gap: 10px;
      padding-right: 4px;
    }

    .cart-list::-webkit-scrollbar {
      width: 8px;
    }

    .cart-list::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .cart-item {
      background: linear-gradient(180deg, #0b1831, #081528);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      padding: 11px;
    }

    .cart-item-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 5px;
    }

    .cart-title {
      font-size: 14px;
      font-weight: 800;
      color: white;
      line-height: 1.2;
    }

    .cart-price {
      color: var(--accent);
      font-weight: 800;
      font-size: 14px;
      white-space: nowrap;
    }

    .cart-meta {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.35;
    }

    .cart-remove {
      margin-top: 8px;
      border: none;
      background: linear-gradient(180deg, var(--red), var(--red-2));
      color: white;
      border-radius: 9px;
      padding: 8px 11px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 800;
    }

    .empty-cart {
      background: linear-gradient(180deg, #0b1831, #081528);
      border: 1px dashed rgba(255,255,255,0.10);
      border-radius: 14px;
      color: var(--muted);
      font-size: 14px;
      padding: 18px;
      text-align: center;
    }

    .checkout-box {
      flex: 1;
      min-height: 0;
      background: linear-gradient(180deg, #0b1730, #081426);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 18px;
      padding: 14px;
      overflow-y: auto;
    }

    .checkout-box::-webkit-scrollbar {
      width: 8px;
    }

    .checkout-box::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .field-block {
      margin-bottom: 12px;
    }

    .field-label {
      font-size: 13px;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 7px;
    }

    .note-input {
      min-height: 72px;
      resize: vertical;
    }

    .customer-box {
      display: none;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 11px;
      margin-bottom: 12px;
    }

    .secondary-btn,
    .checkout-btn {
      width: 100%;
      border: none;
      border-radius: 13px;
      padding: 12px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .secondary-btn {
      background: linear-gradient(180deg, #2b3e61, #223450);
      color: white;
      border: 1px solid rgba(255,255,255,0.08);
      margin-bottom: 10px;
    }

    .checkout-btn {
      background: linear-gradient(180deg, var(--green), var(--green-2));
      color: white;
      margin-top: 8px;
    }

    .checkout-btn:hover,
    .secondary-btn:hover {
      transform: translateY(-1px);
    }

    .total-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 12px;
      margin-top: 4px;
    }

    .total-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    .total-price {
      color: var(--accent);
      font-size: 34px;
      font-weight: 800;
      line-height: 1.05;
      word-break: break-word;
    }

    .push-stack {
      position: fixed;
      right: 16px;
      top: 116px;
      width: 360px;
      max-height: calc(100vh - 160px);
      overflow-y: auto;
      display: grid;
      gap: 10px;
      z-index: 55;
      padding-right: 2px;
    }

    .push-stack::-webkit-scrollbar {
      width: 8px;
    }

    .push-stack::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .push-card {
      background: linear-gradient(180deg, rgba(16,30,52,0.98), rgba(11,21,41,0.98));
      border: 1px solid rgba(251,191,36,0.18);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 12px;
      animation: pushIn 0.22s ease;
    }

    @keyframes pushIn {
      from {
        opacity: 0;
        transform: translateX(18px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .push-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .push-title {
      font-size: 14px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
    }

    .push-close {
      border: none;
      background: rgba(255,255,255,0.06);
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
    }

    .push-info {
      display: grid;
      gap: 4px;
      font-size: 13px;
      color: #dbe8fd;
      margin-bottom: 8px;
    }

    .push-sum {
      color: #fff;
      font-weight: 800;
    }

    .push-items {
      display: grid;
      gap: 6px;
      margin-bottom: 10px;
    }

    .push-item {
      background: rgba(255,255,255,0.04);
      border-radius: 10px;
      padding: 8px 9px;
      font-size: 12px;
      color: #dbe7fb;
      line-height: 1.35;
    }

    .push-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .push-actions form {
      margin: 0;
      flex: 1;
    }

    .approve-btn,
    .reject-btn {
      width: 100%;
      border: none;
      border-radius: 11px;
      padding: 10px 12px;
      color: white;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
    }

    .approve-btn {
      background: linear-gradient(180deg, var(--green), var(--green-2));
    }

    .reject-btn {
      background: linear-gradient(180deg, var(--red), var(--red-2));
    }

    .signature {
      position: fixed;
      right: 16px;
      bottom: 10px;
      color: rgba(255,255,255,0.35);
      font-size: 13px;
      letter-spacing: 0.5px;
      user-select: none;
      pointer-events: none;
    }

    @media (max-width: 1240px) {
      html, body {
        overflow: auto;
      }

      .wrapper {
        height: auto;
        min-height: 100vh;
        overflow: visible;
      }

      .workspace {
        grid-template-columns: 1fr;
      }

      .products-panel,
      .cart-panel {
        height: auto;
        min-height: auto;
      }

      .products-grid,
      .checkout-box,
      .cart-list {
        height: auto;
        max-height: none;
      }

      .push-stack {
        position: static;
        width: auto;
        max-height: none;
        margin: 0 16px 12px;
      }
    }

    @media (max-width: 860px) {
      .topbar {
        flex-direction: column;
        align-items: stretch;
      }

      .brand-wrap {
        min-width: unset;
      }

      .brand-sub {
        white-space: normal;
      }

      .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .meta-grid,
      .inputs-row {
        grid-template-columns: 1fr;
      }

      .products-grid {
        grid-template-columns: 1fr;
      }

      .topbar-right {
        justify-content: space-between;
      }
    }

    @media (max-width: 520px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .brand {
        font-size: 29px;
      }

      .panel-head h2,
      .cart-head h2 {
        font-size: 22px;
      }

      .push-stack {
        margin: 0 10px 12px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const safeCustomers = Array.isArray(customers) ? customers : [];
    const safePendingOrders = Array.isArray(pendingOrders) ? pendingOrders : [];

    const todayExpenseValue =
      typeof todayExpenses !== "undefined" ? Number(todayExpenses || 0) : 0;

    const todayCashValue =
      typeof todayCash !== "undefined" ? Number(todayCash || 0) : 0;

    const todayCardValue =
      typeof todayCard !== "undefined" ? Number(todayCard || 0) : 0;

    const todayDebtValue =
      typeof todayDebt !== "undefined" ? Number(todayDebt || 0) : 0;

    const categoryMap = {};
    safeProducts.forEach(product => {
      const cat = String(product.category || "").trim();
      if (cat) categoryMap[cat] = true;
    });
    const categoryList = Object.keys(categoryMap);

    function formatStockValue(value) {
      const n = Number(value || 0);
      if (!Number.isFinite(n)) return "0.0";
      return (Math.round(n * 10) / 10).toFixed(1);
    }
  %>

  <div class="wrapper">
    <div class="topbar">
      <div class="brand-wrap">
        <h1 class="brand">Sotuvchi paneli</h1>
        <div class="brand-sub">Kassaga yaqin ko‘rinish — asosiy joy mahsulot va savatga berildi.</div>
      </div>

      <div class="topbar-right">
        <div class="today-badge">Bugungi ko‘rsatkichlar</div>

        <button type="button" class="menu-toggle" id="menuToggle">
          <span class="menu-bars">
            <span></span>
            <span></span>
            <span></span>
          </span>
          Bo‘limlar
        </button>

        <div class="menu-dropdown" id="menuDropdown">
          <div class="menu-title">Sotuvchi bo‘limlari</div>

          <div class="menu-links">
            <a href="/seller/sales">Savdolar</a>
            <a href="/seller/debts">Qarzlar</a>
            <a href="/seller/expenses">Chiqimlar</a>
            <a href="/seller/suppliers">Firmalar</a>
            <a href="/seller/stock-entries">Kirimlar</a>
            <a href="/seller/supplier-payments">Firma to‘lovlari</a>
            <a href="/seller/returns">Qaytimlar</a>
            <a href="/seller/supplier-returns">Firma qaytimlari</a>
            <a href="/auth/logout">Chiqish</a>
          </div>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Bugungi chiqim</div>
        <div class="stat-value gold"><%= todayExpenseValue.toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Bugungi naqd pul</div>
        <div class="stat-value green"><%= todayCashValue.toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Bugungi karta</div>
        <div class="stat-value"><%= todayCardValue.toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Bugungi nasiya</div>
        <div class="stat-value"><%= todayDebtValue.toLocaleString("uz-UZ") %></div>
      </div>
    </div>

    <div class="workspace">
      <div class="left-column">
        <div class="panel products-panel">
          <div class="panel-head">
            <div>
              <h2>Mahsulotlar</h2>
              <div class="panel-sub">Kategoriyalar bo‘yicha ajratilgan, qoldiq esa yaxlitlangan ko‘rinishda chiqadi.</div>
            </div>
          </div>

          <div class="search-row">
            <input
              type="text"
              id="searchInput"
              class="search-input"
              placeholder="Mahsulot yoki kategoriya bo‘yicha qidirish..."
            />
          </div>

          <div class="category-strip" id="categoryStrip">
            <button class="category-chip active" type="button" data-category="all">Barchasi</button>

            <% categoryList.forEach(category => { %>
              <button
                class="category-chip"
                type="button"
                data-category="<%= category.toLowerCase() %>"
              >
                <%= category %>
              </button>
            <% }) %>
          </div>

          <div class="products-body">
            <div class="products-grid" id="productsBox">
              <% safeProducts.forEach(product => { %>
                <div
                  class="product-card"
                  data-name="<%= String(product.name || '').toLowerCase() %>"
                  data-category="<%= String(product.category || '').toLowerCase() %>"
                  data-id="<%= product._id %>"
                  data-product-name="<%= product.name %>"
                  data-unit="<%= product.unit || '-' %>"
                  data-default-price="<%= Number(product.salePrice || 0) %>"
                >
                  <div class="product-top">
                    <div class="product-name"><%= product.name %></div>
                    <div class="unit-badge"><%= product.unit || "-" %></div>
                  </div>

                  <div class="meta-grid">
                    <div class="meta-box">
                      <div class="meta-label">Kategoriya</div>
                      <div class="meta-value"><%= product.category || "-" %></div>
                    </div>

                    <div class="meta-box">
                      <div class="meta-label">Qoldiq</div>
                      <div class="meta-value"><%= formatStockValue(product.stock) %></div>
                    </div>

                    <div class="meta-box">
                      <div class="meta-label">Sotuv narxi</div>
                      <div class="meta-value"><%= Number(product.salePrice || 0).toLocaleString("uz-UZ") %></div>
                    </div>

                    <div class="meta-box">
                      <div class="meta-label">Birlik</div>
                      <div class="meta-value"><%= product.unit || "-" %></div>
                    </div>
                  </div>

                  <div class="inputs-row">
                    <input
                      type="number"
                      step="0.01"
                      placeholder="Miqdor"
                      class="text-input qty-input"
                    />

                    <input
                      type="number"
                      step="0.01"
                      placeholder="Narx"
                      class="text-input price-input"
                      value="<%= Number(product.salePrice || 0) %>"
                    />
                  </div>

                  <button class="add-btn" type="button">Savatga qo‘shish</button>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="right-column">
        <div class="panel cart-panel">
          <div class="cart-head">
            <h2>Savat</h2>
            <div class="cart-count"><span id="cartCount">0</span> ta mahsulot</div>
          </div>

          <div class="cart-body">
            <div id="cartList" class="cart-list">
              <div class="empty-cart">Hozircha savatda mahsulot yo‘q.</div>
            </div>

            <div class="checkout-box">
              <div class="field-block">
                <div class="field-label">To‘lov turi</div>
                <select id="paymentType" class="select-input">
                  <option value="cash">Naqd</option>
                  <option value="card">Karta</option>
                  <option value="transfer">O‘tkazma</option>
                  <option value="debt">Nasiya</option>
                </select>
              </div>

              <div id="customerBox" class="customer-box">
                <div class="field-block">
                  <div class="field-label">Bazadagi mijoz</div>
                  <select id="customerId" class="select-input">
                    <option value="">Mijozni tanlang</option>
                    <% safeCustomers.forEach(customer => { %>
                      <option value="<%= customer._id %>">
                        <%= customer.fullName %> - <%= customer.phone %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <button type="button" id="toggleNewCustomerBtn" class="secondary-btn">
                  + Yangi mijoz qo‘shish
                </button>

                <div id="newCustomerBox" style="display:none;">
                  <div class="field-block">
                    <input
                      type="text"
                      id="newCustomerName"
                      class="text-input"
                      placeholder="Mijoz ismi"
                    />
                  </div>

                  <div class="field-block">
                    <input
                      type="text"
                      id="newCustomerPhone"
                      class="text-input"
                      placeholder="Telefon raqami"
                    />
                  </div>

                  <div class="field-block">
                    <input
                      type="text"
                      id="newCustomerAddress"
                      class="text-input"
                      placeholder="Manzil (ixtiyoriy)"
                    />
                  </div>

                  <div class="field-block" style="margin-bottom:0;">
                    <textarea
                      id="newCustomerNote"
                      class="note-input"
                      placeholder="Mijoz izohi (ixtiyoriy)"
                    ></textarea>
                  </div>
                </div>
              </div>

              <div class="field-block">
                <div class="field-label">Izoh</div>
                <textarea
                  id="saleNote"
                  class="note-input"
                  placeholder="Savdo bo‘yicha izoh yozish mumkin"
                ></textarea>
              </div>

              <div class="total-box">
                <div class="total-label">Jami summa</div>
                <div class="total-price" id="totalPrice">0</div>
              </div>

              <button class="checkout-btn" type="button" onclick="checkoutSale()">
                Savdoni yakunlash
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if (safePendingOrders.length) { %>
    <div class="push-stack" id="pushStack">
      <% safePendingOrders.forEach(order => { %>
        <div class="push-card" id="push-<%= order._id %>">
          <div class="push-head">
            <div class="push-title">Yangi buyurtma — <%= order.workerName || "Ishchi" %></div>
            <button type="button" class="push-close" onclick="dismissPush('<%= order._id %>')">×</button>
          </div>

          <div class="push-info">
            <div><strong>To‘lov turi:</strong> <%= order.paymentType %></div>

            <% if (order.paymentType === "debt") { %>
              <div><strong>Mijoz:</strong> <%= order.customerName || "-" %></div>
              <div><strong>Telefon:</strong> <%= order.customerPhone || "-" %></div>
            <% } %>

            <% if (order.note) { %>
              <div><strong>Izoh:</strong> <%= order.note %></div>
            <% } %>

            <div class="push-sum">Jami: <%= Number(order.totalAmount || 0).toLocaleString("uz-UZ") %></div>
          </div>

          <div class="push-items">
            <% order.items.forEach(item => { %>
              <div class="push-item">
                <strong><%= item.productName %></strong><br />
                <%= item.qty %> <%= item.unit %> × <%= Number(item.price || 0).toLocaleString("uz-UZ") %>
                = <%= Number(item.lineTotal || 0).toLocaleString("uz-UZ") %>
              </div>
            <% }) %>
          </div>

          <div class="push-actions">
            <form action="/seller/pending-orders/<%= order._id %>/approve" method="POST">
              <button class="approve-btn" type="submit">Tasdiqlash</button>
            </form>

            <form action="/seller/pending-orders/<%= order._id %>/reject" method="POST">
              <button class="reject-btn" type="submit">Rad etish</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="signature">SharqTech</div>

  <script>
    const cart = [];
    let activeCategory = "all";

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("uz-UZ");
    }

    function renderCart() {
      const cartList = document.getElementById("cartList");
      const totalPrice = document.getElementById("totalPrice");
      const cartCount = document.getElementById("cartCount");

      cartCount.textContent = cart.length;

      if (cart.length === 0) {
        cartList.innerHTML = '<div class="empty-cart">Hozircha savatda mahsulot yo‘q.</div>';
        totalPrice.textContent = "0";
        return;
      }

      cartList.innerHTML = "";
      let total = 0;

      cart.forEach((item, index) => {
        total += Number(item.lineTotal || 0);

        const div = document.createElement("div");
        div.className = "cart-item";
        div.innerHTML = `
          <div class="cart-item-top">
            <div class="cart-title">${item.name}</div>
            <div class="cart-price">${formatMoney(item.lineTotal)}</div>
          </div>
          <div class="cart-meta">${item.qty} ${item.unit} × ${formatMoney(item.price)}</div>
          <button class="cart-remove" onclick="removeFromCart(${index})">O‘chirish</button>
        `;
        cartList.appendChild(div);
      });

      totalPrice.textContent = formatMoney(total);
    }

    function addToCartFromCard(card) {
      const productId = card.dataset.id;
      const name = card.dataset.productName;
      const unit = card.dataset.unit;
      const defaultPrice = Number(card.dataset.defaultPrice || 0);

      const qtyInput = card.querySelector(".qty-input");
      const priceInput = card.querySelector(".price-input");

      const qty = Number(qtyInput.value);
      const price = Number(priceInput.value || defaultPrice);

      if (!qty || qty <= 0) {
        alert("Miqdorni to‘g‘ri kiriting");
        return;
      }

      if (!price || price <= 0) {
        alert("Narxni to‘g‘ri kiriting");
        return;
      }

      const lineTotal = qty * price;

      cart.push({
        productId,
        name,
        unit,
        qty,
        price,
        lineTotal
      });

      qtyInput.value = "";
      renderCart();
    }

    function removeFromCart(index) {
      cart.splice(index, 1);
      renderCart();
    }

    async function checkoutSale() {
      if (cart.length === 0) {
        alert("Savat bo‘sh");
        return;
      }

      const paymentType = document.getElementById("paymentType").value;
      const note = document.getElementById("saleNote").value;
      const customerId = document.getElementById("customerId")
        ? document.getElementById("customerId").value
        : "";

      const newCustomer = {
        fullName: document.getElementById("newCustomerName")
          ? document.getElementById("newCustomerName").value
          : "",
        phone: document.getElementById("newCustomerPhone")
          ? document.getElementById("newCustomerPhone").value
          : "",
        address: document.getElementById("newCustomerAddress")
          ? document.getElementById("newCustomerAddress").value
          : "",
        note: document.getElementById("newCustomerNote")
          ? document.getElementById("newCustomerNote").value
          : ""
      };

      if (paymentType === "debt") {
        const hasSelectedCustomer = !!customerId;
        const hasNewCustomer =
          newCustomer.fullName.trim() && newCustomer.phone.trim();

        if (!hasSelectedCustomer && !hasNewCustomer) {
          alert("Nasiyaga savdo uchun mijoz tanlang yoki yangi mijoz kiriting");
          return;
        }
      }

      try {
        const response = await fetch("/seller/checkout", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            items: cart,
            paymentType,
            note,
            customerId,
            newCustomer
          })
        });

        const result = await response.json();

        if (!result.success) {
          alert(result.message || "Xatolik yuz berdi");
          return;
        }

        alert(result.message || "Savdo muvaffaqiyatli saqlandi");

        cart.length = 0;
        document.getElementById("saleNote").value = "";
        document.getElementById("paymentType").value = "cash";

        if (document.getElementById("customerId")) {
          document.getElementById("customerId").value = "";
        }

        if (document.getElementById("newCustomerName")) {
          document.getElementById("newCustomerName").value = "";
          document.getElementById("newCustomerPhone").value = "";
          document.getElementById("newCustomerAddress").value = "";
          document.getElementById("newCustomerNote").value = "";
        }

        renderCart();
        toggleCustomerBox();
        window.location.reload();
      } catch (error) {
        console.error(error);
        alert("Server bilan bog‘lanishda xatolik");
      }
    }

    const searchInput = document.getElementById("searchInput");
    const productCards = Array.from(document.querySelectorAll(".product-card"));
    const categoryButtons = Array.from(document.querySelectorAll(".category-chip"));

    function applyProductFilters() {
      const searchValue = (searchInput.value || "").toLowerCase().trim();

      productCards.forEach(card => {
        const name = card.dataset.name || "";
        const category = card.dataset.category || "";

        const matchesSearch =
          !searchValue || name.includes(searchValue) || category.includes(searchValue);

        const matchesCategory =
          activeCategory === "all" || category === activeCategory;

        card.style.display = matchesSearch && matchesCategory ? "" : "none";
      });
    }

    searchInput.addEventListener("input", applyProductFilters);

    categoryButtons.forEach(button => {
      button.addEventListener("click", function () {
        categoryButtons.forEach(btn => btn.classList.remove("active"));
        this.classList.add("active");
        activeCategory = this.dataset.category || "all";
        applyProductFilters();
      });
    });

    document.querySelectorAll(".add-btn").forEach(button => {
      button.addEventListener("click", function () {
        const card = this.closest(".product-card");
        addToCartFromCard(card);
      });
    });

    document.querySelectorAll(".qty-input, .price-input").forEach(input => {
      input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
          const card = this.closest(".product-card");
          addToCartFromCard(card);
        }
      });
    });

    const paymentTypeSelect = document.getElementById("paymentType");
    const customerBox = document.getElementById("customerBox");
    const toggleNewCustomerBtn = document.getElementById("toggleNewCustomerBtn");
    const newCustomerBox = document.getElementById("newCustomerBox");
    const customerSelect = document.getElementById("customerId");

    function toggleCustomerBox() {
      if (paymentTypeSelect.value === "debt") {
        customerBox.style.display = "block";
      } else {
        customerBox.style.display = "none";
        newCustomerBox.style.display = "none";
      }
    }

    if (toggleNewCustomerBtn) {
      toggleNewCustomerBtn.addEventListener("click", function () {
        if (
          newCustomerBox.style.display === "none" ||
          newCustomerBox.style.display === ""
        ) {
          newCustomerBox.style.display = "block";
          if (customerSelect) {
            customerSelect.value = "";
          }
        } else {
          newCustomerBox.style.display = "none";
        }
      });
    }

    if (customerSelect) {
      customerSelect.addEventListener("change", function () {
        if (this.value) {
          newCustomerBox.style.display = "none";
        }
      });
    }

    paymentTypeSelect.addEventListener("change", toggleCustomerBox);

    function dismissPush(id) {
      const el = document.getElementById(`push-${id}`);
      if (el) el.remove();
    }

    const menuToggle = document.getElementById("menuToggle");
    const menuDropdown = document.getElementById("menuDropdown");

    if (menuToggle && menuDropdown) {
      menuToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        menuDropdown.classList.toggle("open");
      });

      menuDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });

      document.addEventListener("click", function () {
        menuDropdown.classList.remove("open");
      });
    }

    toggleCustomerBox();
    applyProductFilters();
    renderCart();
  </script>
</body>
</html>
