<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sotuvchi paneli</title>

  <style>
    :root {
      --bg: #06111f;
      --panel: #0d1c33;
      --panel-2: #09162b;
      --panel-3: #132541;
      --line: rgba(255, 255, 255, 0.08);
      --line-soft: rgba(255, 255, 255, 0.05);
      --text: #eef4ff;
      --muted: #8ea4c7;
      --accent: #fbbf24;
      --accent-2: #ffd15f;
      --green: #22c55e;
      --green-2: #16a34a;
      --red: #ef4444;
      --red-2: #dc2626;
      --blue: #3b82f6;
      --shadow: 0 14px 38px rgba(0, 0, 0, 0.28);
      --radius: 18px;
      --radius-sm: 12px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow: hidden;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 24%),
        var(--bg);
      color: var(--text);
    }

    body {
      min-height: 100vh;
    }

    .wrapper {
      max-width: 1540px;
      margin: 0 auto;
      height: 100vh;
      padding: 12px 16px 34px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      overflow: hidden;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      min-height: 66px;
    }

    .brand-wrap {
      min-width: 290px;
    }

    .brand {
      margin: 0;
      font-size: 36px;
      line-height: 1.02;
      font-weight: 800;
      letter-spacing: -0.8px;
      color: var(--accent);
    }

    .brand-sub {
      margin-top: 6px;
      color: var(--muted);
      font-size: 14px;
      white-space: nowrap;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
      position: relative;
    }

    .today-badge {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(251,191,36,0.10);
      border: 1px solid rgba(251,191,36,0.18);
      color: var(--accent);
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .menu-toggle {
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #182c4b, #12213a);
      color: white;
      padding: 11px 15px;
      border-radius: 14px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 9px;
      transition: 0.18s ease;
      box-shadow: var(--shadow);
    }

    .menu-toggle:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.22);
    }

    .menu-bars {
      width: 16px;
      height: 12px;
      display: grid;
      gap: 3px;
    }

    .menu-bars span {
      display: block;
      height: 2px;
      background: #fff;
      border-radius: 999px;
    }

    .menu-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      width: 270px;
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 10px;
      display: none;
      z-index: 80;
    }

    .menu-dropdown.open {
      display: block;
      animation: fadeDown 0.18s ease;
    }

    @keyframes fadeDown {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .menu-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      margin: 4px 6px 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .menu-links {
      display: grid;
      gap: 8px;
    }

    .menu-links a {
      text-decoration: none;
      color: white;
      background: linear-gradient(180deg, #142540, #102038);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 11px 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      transition: 0.18s ease;
    }

    .menu-links a:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, #1a2f50, #152741);
      border-color: rgba(251,191,36,0.20);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      min-height: 82px;
    }

    .stat-card {
      background: linear-gradient(180deg, rgba(19,37,65,0.96), rgba(12,24,46,0.96));
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 12px 14px;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 82px;
    }

    .stat-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 22px;
      font-weight: 800;
      line-height: 1;
      color: white;
      word-break: break-word;
    }

    .stat-value.gold {
      color: var(--accent);
    }

    .stat-value.green {
      color: #86efac;
    }

    .workspace {
      flex: 1;
      min-height: 0;
      display: grid;
      grid-template-columns: minmax(0, 1.9fr) minmax(390px, 0.95fr);
      gap: 12px;
      overflow: hidden;
    }

    .left-column,
    .right-column {
      min-height: 0;
      overflow: hidden;
    }

    .panel {
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .products-panel {
      height: 100%;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .panel-head {
      padding: 15px 16px 8px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .panel-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 24px;
      line-height: 1.04;
    }

    .panel-sub {
      margin-top: 4px;
      color: var(--muted);
      font-size: 13px;
    }

    .search-row {
      padding: 0 16px 10px;
    }

    .search-input,
    .select-input,
    .text-input,
    .note-input {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 15px;
      outline: none;
    }

    .search-input:focus,
    .select-input:focus,
    .text-input:focus,
    .note-input:focus {
      border-color: rgba(59,130,246,0.42);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .products-layout {
      flex: 1;
      min-height: 0;
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 12px;
      padding: 0 16px 16px;
      overflow: hidden;
    }

    .category-panel {
      background: linear-gradient(180deg, #0b1730, #081426);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 18px;
      padding: 12px;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .category-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .category-list {
      display: grid;
      gap: 8px;
      overflow-y: auto;
      padding-right: 3px;
    }

    .category-list::-webkit-scrollbar {
      width: 7px;
    }

    .category-list::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .category-btn {
      width: 100%;
      text-align: left;
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #d7e7ff;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .category-btn:hover {
      background: #182c4c;
    }

    .category-btn.active {
      background: linear-gradient(180deg, var(--accent), #f1b61e);
      color: #131923;
      border-color: rgba(251,191,36,0.24);
    }

    .product-list-panel {
      background: linear-gradient(180deg, #0b1730, #081426);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 18px;
      min-height: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .product-list-head {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .product-list {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      padding: 8px;
      display: grid;
      gap: 8px;
      align-content: start;
    }

    .product-list::-webkit-scrollbar {
      width: 8px;
    }

    .product-list::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .product-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
      background: linear-gradient(180deg, #0d1b33, #0a162b);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 10px 12px;
      transition: 0.18s ease;
    }

    .product-row:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.16);
    }

    .product-info {
      min-width: 0;
    }

    .product-name {
      font-size: 15px;
      font-weight: 800;
      color: white;
      line-height: 1.2;
      word-break: break-word;
      margin-bottom: 3px;
    }

    .product-cat {
      font-size: 12px;
      color: var(--muted);
      word-break: break-word;
    }

    .add-mini-btn {
      width: 40px;
      height: 40px;
      border: none;
      border-radius: 12px;
      background: linear-gradient(180deg, var(--accent), #efb318);
      color: #101722;
      font-size: 24px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: inset 0 -1px 0 rgba(0,0,0,0.15);
    }

    .add-mini-btn:hover {
      transform: scale(1.03);
      background: linear-gradient(180deg, var(--accent-2), #f1b61e);
    }

    .cart-panel {
      height: 100%;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .cart-head {
      padding: 16px 16px 10px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .cart-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 24px;
    }

    .cart-count {
      background: rgba(34,197,94,0.12);
      color: #9ff0b8;
      border: 1px solid rgba(34,197,94,0.18);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .cart-main {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .cart-list {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      padding: 12px 16px;
      display: grid;
      gap: 10px;
      align-content: start;
    }

    .cart-list::-webkit-scrollbar {
      width: 8px;
    }

    .cart-list::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .empty-cart {
      background: linear-gradient(180deg, #0b1831, #081528);
      border: 1px dashed rgba(255,255,255,0.10);
      border-radius: 14px;
      color: var(--muted);
      font-size: 14px;
      padding: 18px;
      text-align: center;
    }

    .cart-item {
      background: linear-gradient(180deg, #0b1831, #081528);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 11px;
    }

    .cart-item-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .cart-title {
      font-size: 14px;
      font-weight: 800;
      color: white;
      line-height: 1.2;
    }

    .cart-line-total {
      color: var(--accent);
      font-weight: 800;
      font-size: 14px;
      white-space: nowrap;
    }

    .cart-controls {
      display: grid;
      grid-template-columns: auto 62px auto 1fr auto;
      gap: 8px;
      align-items: center;
    }

    .qty-btn,
    .remove-btn {
      border: none;
      cursor: pointer;
      font-weight: 800;
      border-radius: 10px;
      transition: 0.18s ease;
    }

    .qty-btn {
      width: 36px;
      height: 36px;
      background: #1c3050;
      color: white;
      font-size: 18px;
    }

    .qty-btn:hover {
      background: #27416a;
    }

    .remove-btn {
      height: 36px;
      padding: 0 12px;
      background: linear-gradient(180deg, var(--red), var(--red-2));
      color: white;
      font-size: 12px;
    }

    .remove-btn:hover {
      filter: brightness(1.05);
    }

    .qty-input,
    .price-edit {
      width: 100%;
      height: 36px;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 10px;
      padding: 0 10px;
      font-size: 14px;
      outline: none;
      font-weight: 700;
    }

    .price-edit-wrap {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3px;
    }

    .mini-label {
      font-size: 11px;
      color: var(--muted);
      line-height: 1;
    }

    .cart-footer {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 12px 16px 16px;
      background: linear-gradient(180deg, rgba(11,23,48,0.95), rgba(8,20,38,0.98));
      display: grid;
      gap: 10px;
    }

    .payment-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .payment-btn {
      border: 1px solid rgba(255,255,255,0.07);
      background: #12213a;
      color: #dce8fb;
      border-radius: 12px;
      padding: 10px 8px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .payment-btn.active {
      background: linear-gradient(180deg, var(--accent), #f0b61d);
      color: #101722;
      border-color: rgba(251,191,36,0.22);
    }

    .footer-actions {
      display: flex;
      gap: 8px;
    }

    .ghost-btn,
    .checkout-btn {
      border: none;
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .ghost-btn {
      flex: 0 0 auto;
      background: linear-gradient(180deg, #233754, #1a2c46);
      color: white;
      border: 1px solid rgba(255,255,255,0.07);
    }

    .ghost-btn:hover {
      transform: translateY(-1px);
    }

    .checkout-btn {
      flex: 1;
      background: linear-gradient(180deg, var(--green), var(--green-2));
      color: white;
      box-shadow: 0 8px 18px rgba(34,197,94,0.18);
    }

    .checkout-btn:hover {
      transform: translateY(-1px);
    }

    .total-box {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 12px 14px;
    }

    .total-label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .total-price {
      color: var(--accent);
      font-size: 30px;
      font-weight: 800;
      line-height: 1.05;
      word-break: break-word;
      text-align: right;
    }

    .extra-panel {
      display: none;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 14px;
      padding: 10px;
    }

    .extra-panel.open {
      display: block;
    }

    .field-block {
      margin-bottom: 10px;
    }

    .field-block:last-child {
      margin-bottom: 0;
    }

    .field-label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 6px;
    }

    .note-input {
      min-height: 70px;
      resize: vertical;
    }

    .customer-box {
      display: none;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px;
      margin-top: 10px;
    }

    .secondary-btn {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 10px 12px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      background: linear-gradient(180deg, #2b3e61, #223450);
      color: white;
      margin-top: 8px;
    }

    .push-stack {
      position: fixed;
      right: 16px;
      top: 118px;
      width: 360px;
      max-height: calc(100vh - 170px);
      overflow-y: auto;
      display: grid;
      gap: 10px;
      z-index: 70;
      padding-right: 2px;
    }

    .push-stack::-webkit-scrollbar {
      width: 8px;
    }

    .push-stack::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .push-card {
      background: linear-gradient(180deg, rgba(16,30,52,0.98), rgba(11,21,41,0.98));
      border: 1px solid rgba(251,191,36,0.18);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 12px;
      animation: pushIn 0.22s ease;
    }

    .push-card.low-stock {
      border-color: rgba(239,68,68,0.18);
    }

    @keyframes pushIn {
      from {
        opacity: 0;
        transform: translateX(18px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .push-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .push-title {
      font-size: 14px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
    }

    .push-card.low-stock .push-title {
      color: #fda4af;
    }

    .push-close {
      border: none;
      background: rgba(255,255,255,0.06);
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
    }

    .push-info {
      display: grid;
      gap: 4px;
      font-size: 13px;
      color: #dbe8fd;
      margin-bottom: 8px;
    }

    .push-sum {
      color: #fff;
      font-weight: 800;
    }

    .push-items {
      display: grid;
      gap: 6px;
      margin-bottom: 10px;
    }

    .push-item {
      background: rgba(255,255,255,0.04);
      border-radius: 10px;
      padding: 8px 9px;
      font-size: 12px;
      color: #dbe7fb;
      line-height: 1.35;
    }

    .push-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .push-actions form {
      margin: 0;
      flex: 1;
    }

    .approve-btn,
    .reject-btn {
      width: 100%;
      border: none;
      border-radius: 11px;
      padding: 10px 12px;
      color: white;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
    }

    .approve-btn {
      background: linear-gradient(180deg, var(--green), var(--green-2));
    }

    .reject-btn {
      background: linear-gradient(180deg, var(--red), var(--red-2));
    }

    .low-stock-stack {
      position: fixed;
      left: 16px;
      bottom: 16px;
      width: 310px;
      max-height: 260px;
      overflow-y: auto;
      display: grid;
      gap: 10px;
      z-index: 69;
      padding-right: 2px;
    }

    .low-stock-stack::-webkit-scrollbar {
      width: 8px;
    }

    .low-stock-stack::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .signature {
      position: fixed;
      right: 16px;
      bottom: 10px;
      color: rgba(255,255,255,0.35);
      font-size: 13px;
      letter-spacing: 0.5px;
      user-select: none;
      pointer-events: none;
    }

    @media (max-width: 1280px) {
      html, body {
        overflow: auto;
      }

      .wrapper {
        height: auto;
        min-height: 100vh;
        overflow: visible;
      }

      .workspace {
        grid-template-columns: 1fr;
      }

      .products-panel,
      .cart-panel {
        height: auto;
        min-height: auto;
      }

      .products-layout {
        grid-template-columns: 1fr;
      }

      .product-list,
      .cart-list {
        max-height: none;
      }

      .push-stack,
      .low-stock-stack {
        position: static;
        width: auto;
        max-height: none;
        margin: 0 16px 10px;
      }
    }

    @media (max-width: 860px) {
      .topbar {
        flex-direction: column;
        align-items: stretch;
      }

      .brand-wrap {
        min-width: unset;
      }

      .brand-sub {
        white-space: normal;
      }

      .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .cart-controls {
        grid-template-columns: auto 58px auto 1fr;
      }

      .remove-btn {
        grid-column: 1 / -1;
      }

      .payment-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 520px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .brand {
        font-size: 29px;
      }

      .panel-head h2,
      .cart-head h2 {
        font-size: 22px;
      }

      .footer-actions {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const safeCustomers = Array.isArray(customers) ? customers : [];
    const safePendingOrders = Array.isArray(pendingOrders) ? pendingOrders : [];

    const todayExpenseValue =
      typeof todayExpenses !== "undefined" ? Number(todayExpenses || 0) : 0;

    const todayCashValue =
      typeof todayCash !== "undefined" ? Number(todayCash || 0) : 0;

    const todayCardValue =
      typeof todayCard !== "undefined" ? Number(todayCard || 0) : 0;

    const todayDebtValue =
      typeof todayDebt !== "undefined" ? Number(todayDebt || 0) : 0;

    const categoryMap = {};
    safeProducts.forEach(product => {
      const cat = String(product.category || "").trim();
      if (cat) categoryMap[cat] = true;
    });
    const categoryList = Object.keys(categoryMap);

    const lowStockProducts = safeProducts.filter(product => Number(product.stock || 0) < 10);

    function formatStockValue(value) {
      const n = Number(value || 0);
      if (!Number.isFinite(n)) return "0.0";
      return (Math.round(n * 10) / 10).toFixed(1);
    }
  %>

  <div class="wrapper">
    <div class="topbar">
      <div class="brand-wrap">
        <h1 class="brand">Sotuvchi paneli</h1>
        <div class="brand-sub">Toza POS/kassa oynasi — tez qo‘shish, tez tahrirlash, tez yakunlash.</div>
      </div>

      <div class="topbar-right">
        <div class="today-badge">Bugungi ko‘rsatkichlar</div>

        <button type="button" class="menu-toggle" id="menuToggle">
          <span class="menu-bars">
            <span></span>
            <span></span>
            <span></span>
          </span>
          Bo‘limlar
        </button>

        <div class="menu-dropdown" id="menuDropdown">
          <div class="menu-title">Sotuvchi bo‘limlari</div>

          <div class="menu-links">
            <a href="/seller/sales">Savdolar</a>
            <a href="/seller/debts">Qarzlar</a>
            <a href="/seller/expenses">Chiqimlar</a>
            <a href="/seller/suppliers">Firmalar</a>
            <a href="/seller/stock-entries">Kirimlar</a>
            <a href="/seller/supplier-payments">Firma to‘lovlari</a>
            <a href="/seller/returns">Qaytimlar</a>
            <a href="/seller/supplier-returns">Firma qaytimlari</a>
            <a href="/auth/logout">Chiqish</a>
          </div>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Bugungi chiqim</div>
        <div class="stat-value gold"><%= todayExpenseValue.toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Bugungi naqd pul</div>
        <div class="stat-value green"><%= todayCashValue.toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Bugungi karta</div>
        <div class="stat-value"><%= todayCardValue.toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Bugungi nasiya</div>
        <div class="stat-value"><%= todayDebtValue.toLocaleString("uz-UZ") %></div>
      </div>
    </div>

    <div class="workspace">
      <div class="left-column">
        <div class="panel products-panel">
          <div class="panel-head">
            <div>
              <h2>Mahsulotlar</h2>
              <div class="panel-sub">Bu yerda faqat tanlash va qo‘shish. Narx savat ichida o‘zgartiriladi.</div>
            </div>
          </div>

          <div class="search-row">
            <input
              type="text"
              id="searchInput"
              class="search-input"
              placeholder="Mahsulot yoki kategoriya bo‘yicha qidirish..."
            />
          </div>

          <div class="products-layout">
            <div class="category-panel">
              <div class="category-title">Kategoriyalar</div>

              <div class="category-list">
                <button class="category-btn active" type="button" data-category="all">Barchasi</button>

                <% categoryList.forEach(category => { %>
                  <button
                    class="category-btn"
                    type="button"
                    data-category="<%= category.toLowerCase() %>"
                  >
                    <%= category %>
                  </button>
                <% }) %>
              </div>
            </div>

            <div class="product-list-panel">
              <div class="product-list-head">Mahsulot nomini tanlang va o‘ng tomondagi savatga qo‘shing</div>

              <div class="product-list" id="productList">
                <% safeProducts.forEach(product => { %>
                  <div
                    class="product-row"
                    data-name="<%= String(product.name || '').toLowerCase() %>"
                    data-category="<%= String(product.category || '').toLowerCase() %>"
                    data-id="<%= product._id %>"
                    data-product-name="<%= product.name %>"
                    data-unit="<%= product.unit || '-' %>"
                    data-default-price="<%= Number(product.salePrice || 0) %>"
                  >
                    <div class="product-info">
                      <div class="product-name"><%= product.name %></div>
                      <div class="product-cat"><%= product.category || "Kategoriya yo‘q" %></div>
                    </div>

                    <button class="add-mini-btn" type="button">+</button>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="right-column">
        <div class="panel cart-panel">
          <div class="cart-head">
            <h2>Savdo</h2>
            <div class="cart-count"><span id="cartCount">0</span> ta mahsulot</div>
          </div>

          <div class="cart-main">
            <div id="cartList" class="cart-list">
              <div class="empty-cart">Hozircha savatda mahsulot yo‘q.</div>
            </div>

            <div class="cart-footer">
              <div class="payment-row">
                <button class="payment-btn active" type="button" data-payment="cash">Naqd</button>
                <button class="payment-btn" type="button" data-payment="card">Karta</button>
                <button class="payment-btn" type="button" data-payment="transfer">O‘tkazma</button>
                <button class="payment-btn" type="button" data-payment="debt">Nasiya</button>
              </div>

              <input type="hidden" id="paymentTypeValue" value="cash" />

              <div class="extra-panel" id="extraPanel">
                <div class="field-block">
                  <div class="field-label">Izoh</div>
                  <textarea
                    id="saleNote"
                    class="note-input"
                    placeholder="Savdo bo‘yicha izoh yozish mumkin"
                  ></textarea>
                </div>

                <div id="customerBox" class="customer-box">
                  <div class="field-block">
                    <div class="field-label">Bazadagi mijoz</div>
                    <select id="customerId" class="select-input">
                      <option value="">Mijozni tanlang</option>
                      <% safeCustomers.forEach(customer => { %>
                        <option value="<%= customer._id %>">
                          <%= customer.fullName %> - <%= customer.phone %>
                        </option>
                      <% }) %>
                    </select>
                  </div>

                  <button type="button" id="toggleNewCustomerBtn" class="secondary-btn">
                    + Yangi mijoz qo‘shish
                  </button>

                  <div id="newCustomerBox" style="display:none; margin-top: 10px;">
                    <div class="field-block">
                      <input
                        type="text"
                        id="newCustomerName"
                        class="text-input"
                        placeholder="Mijoz ismi"
                      />
                    </div>

                    <div class="field-block">
                      <input
                        type="text"
                        id="newCustomerPhone"
                        class="text-input"
                        placeholder="Telefon raqami"
                      />
                    </div>

                    <div class="field-block">
                      <input
                        type="text"
                        id="newCustomerAddress"
                        class="text-input"
                        placeholder="Manzil (ixtiyoriy)"
                      />
                    </div>

                    <div class="field-block">
                      <textarea
                        id="newCustomerNote"
                        class="note-input"
                        placeholder="Mijoz izohi (ixtiyoriy)"
                      ></textarea>
                    </div>
                  </div>
                </div>
              </div>

              <div class="total-box">
                <div>
                  <div class="total-label">Jami summa</div>
                </div>
                <div class="total-price" id="totalPrice">0</div>
              </div>

              <div class="footer-actions">
                <button class="ghost-btn" type="button" id="toggleExtraBtn">Qo‘shimcha</button>
                <button class="checkout-btn" type="button" onclick="checkoutSale()">Savdoni yakunlash</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if (safePendingOrders.length) { %>
      <div class="push-stack" id="pushStack">
        <% safePendingOrders.forEach(order => { %>
          <div class="push-card" id="push-<%= order._id %>">
            <div class="push-head">
              <div class="push-title">Yangi buyurtma — <%= order.workerName || "Ishchi" %></div>
              <button type="button" class="push-close" onclick="dismissPush('<%= order._id %>')">×</button>
            </div>

            <div class="push-info">
              <div><strong>To‘lov turi:</strong> <%= order.paymentType %></div>

              <% if (order.paymentType === "debt") { %>
                <div><strong>Mijoz:</strong> <%= order.customerName || "-" %></div>
                <div><strong>Telefon:</strong> <%= order.customerPhone || "-" %></div>
              <% } %>

              <% if (order.note) { %>
                <div><strong>Izoh:</strong> <%= order.note %></div>
              <% } %>

              <div class="push-sum">Jami: <%= Number(order.totalAmount || 0).toLocaleString("uz-UZ") %></div>
            </div>

            <div class="push-items">
              <% order.items.forEach(item => { %>
                <div class="push-item">
                  <strong><%= item.productName %></strong><br />
                  <%= item.qty %> <%= item.unit %> × <%= Number(item.price || 0).toLocaleString("uz-UZ") %>
                  = <%= Number(item.lineTotal || 0).toLocaleString("uz-UZ") %>
                </div>
              <% }) %>
            </div>

            <div class="push-actions">
              <form action="/seller/pending-orders/<%= order._id %>/approve" method="POST">
                <button class="approve-btn" type="submit">Tasdiqlash</button>
              </form>

              <form action="/seller/pending-orders/<%= order._id %>/reject" method="POST">
                <button class="reject-btn" type="submit">Rad etish</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (lowStockProducts.length) { %>
      <div class="low-stock-stack" id="lowStockStack">
        <% lowStockProducts.slice(0, 5).forEach(product => { %>
          <div class="push-card low-stock" id="low-stock-<%= product._id %>">
            <div class="push-head">
              <div class="push-title">Kam qoldi</div>
              <button type="button" class="push-close" onclick="dismissLowStock('<%= product._id %>')">×</button>
            </div>

            <div class="push-info">
              <div><strong>Mahsulot:</strong> <%= product.name %></div>
              <div><strong>Qoldiq:</strong> <%= formatStockValue(product.stock) %> <%= product.unit || "" %></div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="signature">SharqTech</div>

  <script>
    const cart = [];
    let activeCategory = "all";

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("uz-UZ");
    }

    function renderCart() {
      const cartList = document.getElementById("cartList");
      const totalPrice = document.getElementById("totalPrice");
      const cartCount = document.getElementById("cartCount");

      cartCount.textContent = cart.length;

      if (cart.length === 0) {
        cartList.innerHTML = '<div class="empty-cart">Hozircha savatda mahsulot yo‘q.</div>';
        totalPrice.textContent = "0";
        return;
      }

      let total = 0;

      cartList.innerHTML = cart.map((item, index) => {
        const lineTotal = Number(item.qty || 0) * Number(item.price || 0);
        total += lineTotal;

        return `
          <div class="cart-item">
            <div class="cart-item-top">
              <div class="cart-title">${item.name}</div>
              <div class="cart-line-total">${formatMoney(lineTotal)}</div>
            </div>

            <div class="cart-controls">
              <button class="qty-btn" type="button" onclick="decreaseQty(${index})">-</button>

              <input
                class="qty-input"
                type="number"
                step="0.01"
                min="0.01"
                value="${item.qty}"
                oninput="updateCartQty(${index}, this.value)"
              />

              <button class="qty-btn" type="button" onclick="increaseQty(${index})">+</button>

              <div class="price-edit-wrap">
                <div class="mini-label">Narx</div>
                <input
                  class="price-edit"
                  type="number"
                  step="0.01"
                  min="0.01"
                  value="${item.price}"
                  oninput="updateCartPrice(${index}, this.value)"
                />
              </div>

              <button class="remove-btn" type="button" onclick="removeFromCart(${index})">O‘chirish</button>
            </div>
          </div>
        `;
      }).join("");

      totalPrice.textContent = formatMoney(total);
    }

    function addProductToCart(product) {
      const foundIndex = cart.findIndex(item => item.productId === product.productId);

      if (foundIndex > -1) {
        cart[foundIndex].qty = Number(cart[foundIndex].qty || 0) + 1;
      } else {
        cart.push({
          productId: product.productId,
          name: product.name,
          unit: product.unit,
          qty: 1,
          price: Number(product.defaultPrice || 0)
        });
      }

      renderCart();
    }

    function removeFromCart(index) {
      cart.splice(index, 1);
      renderCart();
    }

    function increaseQty(index) {
      cart[index].qty = Number(cart[index].qty || 0) + 1;
      renderCart();
    }

    function decreaseQty(index) {
      const current = Number(cart[index].qty || 0);

      if (current <= 1) {
        cart.splice(index, 1);
      } else {
        cart[index].qty = current - 1;
      }

      renderCart();
    }

    function updateCartQty(index, value) {
      let qty = Number(value);

      if (!qty || qty <= 0) {
        qty = 1;
      }

      cart[index].qty = qty;
      renderCart();
    }

    function updateCartPrice(index, value) {
      let price = Number(value);

      if (!price || price <= 0) {
        price = 1;
      }

      cart[index].price = price;
      renderCart();
    }

    async function checkoutSale() {
      if (cart.length === 0) {
        alert("Savat bo‘sh");
        return;
      }

      const paymentType = document.getElementById("paymentTypeValue").value;
      const note = document.getElementById("saleNote").value;
      const customerId = document.getElementById("customerId")
        ? document.getElementById("customerId").value
        : "";

      const newCustomer = {
        fullName: document.getElementById("newCustomerName")
          ? document.getElementById("newCustomerName").value
          : "",
        phone: document.getElementById("newCustomerPhone")
          ? document.getElementById("newCustomerPhone").value
          : "",
        address: document.getElementById("newCustomerAddress")
          ? document.getElementById("newCustomerAddress").value
          : "",
        note: document.getElementById("newCustomerNote")
          ? document.getElementById("newCustomerNote").value
          : ""
      };

      if (paymentType === "debt") {
        const hasSelectedCustomer = !!customerId;
        const hasNewCustomer =
          newCustomer.fullName.trim() && newCustomer.phone.trim();

        if (!hasSelectedCustomer && !hasNewCustomer) {
          alert("Nasiyaga savdo uchun mijoz tanlang yoki yangi mijoz kiriting");
          return;
        }
      }

      const items = cart.map(item => ({
        productId: item.productId,
        name: item.name,
        unit: item.unit,
        qty: Number(item.qty || 0),
        price: Number(item.price || 0),
        lineTotal: Number(item.qty || 0) * Number(item.price || 0)
      }));

      try {
        const response = await fetch("/seller/checkout", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            items,
            paymentType,
            note,
            customerId,
            newCustomer
          })
        });

        const result = await response.json();

        if (!result.success) {
          alert(result.message || "Xatolik yuz berdi");
          return;
        }

        alert(result.message || "Savdo muvaffaqiyatli saqlandi");

        cart.length = 0;
        document.getElementById("saleNote").value = "";
        setPaymentType("cash");

        if (document.getElementById("customerId")) {
          document.getElementById("customerId").value = "";
        }

        if (document.getElementById("newCustomerName")) {
          document.getElementById("newCustomerName").value = "";
          document.getElementById("newCustomerPhone").value = "";
          document.getElementById("newCustomerAddress").value = "";
          document.getElementById("newCustomerNote").value = "";
        }

        renderCart();
        toggleCustomerBox();
        window.location.reload();
      } catch (error) {
        console.error(error);
        alert("Server bilan bog‘lanishda xatolik");
      }
    }

    const searchInput = document.getElementById("searchInput");
    const productRows = Array.from(document.querySelectorAll(".product-row"));
    const categoryButtons = Array.from(document.querySelectorAll(".category-btn"));

    function applyProductFilters() {
      const searchValue = (searchInput.value || "").toLowerCase().trim();

      productRows.forEach(row => {
        const name = row.dataset.name || "";
        const category = row.dataset.category || "";

        const matchesSearch =
          !searchValue || name.includes(searchValue) || category.includes(searchValue);

        const matchesCategory =
          activeCategory === "all" || category === activeCategory;

        row.style.display = matchesSearch && matchesCategory ? "" : "none";
      });
    }

    searchInput.addEventListener("input", applyProductFilters);

    categoryButtons.forEach(button => {
      button.addEventListener("click", function () {
        categoryButtons.forEach(btn => btn.classList.remove("active"));
        this.classList.add("active");
        activeCategory = this.dataset.category || "all";
        applyProductFilters();
      });
    });

    document.querySelectorAll(".add-mini-btn").forEach(button => {
      button.addEventListener("click", function () {
        const row = this.closest(".product-row");

        addProductToCart({
          productId: row.dataset.id,
          name: row.dataset.productName,
          unit: row.dataset.unit,
          defaultPrice: row.dataset.defaultPrice
        });
      });
    });

    document.querySelectorAll(".product-row").forEach(row => {
      row.addEventListener("dblclick", function () {
        addProductToCart({
          productId: row.dataset.id,
          name: row.dataset.productName,
          unit: row.dataset.unit,
          defaultPrice: row.dataset.defaultPrice
        });
      });
    });

    const paymentButtons = Array.from(document.querySelectorAll(".payment-btn"));
    const paymentTypeValue = document.getElementById("paymentTypeValue");
    const extraPanel = document.getElementById("extraPanel");
    const toggleExtraBtn = document.getElementById("toggleExtraBtn");

    function setPaymentType(type) {
      paymentTypeValue.value = type;

      paymentButtons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.payment === type);
      });

      if (type === "debt") {
        extraPanel.classList.add("open");
      }

      toggleCustomerBox();
    }

    paymentButtons.forEach(button => {
      button.addEventListener("click", function () {
        setPaymentType(this.dataset.payment);
      });
    });

    if (toggleExtraBtn) {
      toggleExtraBtn.addEventListener("click", function () {
        extraPanel.classList.toggle("open");
      });
    }

    const customerBox = document.getElementById("customerBox");
    const toggleNewCustomerBtn = document.getElementById("toggleNewCustomerBtn");
    const newCustomerBox = document.getElementById("newCustomerBox");
    const customerSelect = document.getElementById("customerId");

    function toggleCustomerBox() {
      if (paymentTypeValue.value === "debt") {
        customerBox.style.display = "block";
      } else {
        customerBox.style.display = "none";
        newCustomerBox.style.display = "none";
      }
    }

    if (toggleNewCustomerBtn) {
      toggleNewCustomerBtn.addEventListener("click", function () {
        if (
          newCustomerBox.style.display === "none" ||
          newCustomerBox.style.display === ""
        ) {
          newCustomerBox.style.display = "block";
          if (customerSelect) {
            customerSelect.value = "";
          }
        } else {
          newCustomerBox.style.display = "none";
        }
      });
    }

    if (customerSelect) {
      customerSelect.addEventListener("change", function () {
        if (this.value) {
          newCustomerBox.style.display = "none";
        }
      });
    }

    function dismissPush(id) {
      const el = document.getElementById(`push-${id}`);
      if (el) el.remove();
    }

    function dismissLowStock(id) {
      const el = document.getElementById(`low-stock-${id}`);
      if (el) el.remove();
    }

    const menuToggle = document.getElementById("menuToggle");
    const menuDropdown = document.getElementById("menuDropdown");

    if (menuToggle && menuDropdown) {
      menuToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        menuDropdown.classList.toggle("open");
      });

      menuDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });

      document.addEventListener("click", function () {
        menuDropdown.classList.remove("open");
      });
    }

    toggleCustomerBox();
    applyProductFilters();
    renderCart();
  </script>
</body>
</html>
