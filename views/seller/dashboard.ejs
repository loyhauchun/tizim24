<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sotuvchi paneli</title>

  <style>
    :root {
      --bg: #081225;
      --panel: #0f1b31;
      --panel-2: #13223d;
      --panel-3: #0b172d;
      --line: rgba(255, 255, 255, 0.08);
      --text: #e5eefc;
      --muted: #96a5c2;
      --accent: #fbbf24;
      --accent-dark: #d29b12;
      --green: #22c55e;
      --green-dark: #16a34a;
      --red: #ef4444;
      --red-dark: #dc2626;
      --blue: #3b82f6;
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
      --radius: 18px;
      --radius-sm: 12px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 26%),
        var(--bg);
      color: var(--text);
    }

    body {
      min-height: 100vh;
    }

    .wrapper {
      max-width: 1450px;
      margin: 0 auto;
      padding: 22px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 18px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .header-left h1 {
      margin: 0 0 8px;
      font-size: 34px;
      line-height: 1.1;
      color: var(--accent);
      letter-spacing: -0.5px;
    }

    .header-left p {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
    }

    .nav-links {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-links a {
      text-decoration: none;
      color: #fff;
      background: linear-gradient(180deg, #182945, #12213a);
      border: 1px solid var(--line);
      padding: 11px 15px;
      border-radius: 12px;
      font-size: 15px;
      transition: 0.2s ease;
      white-space: nowrap;
    }

    .nav-links a:hover {
      transform: translateY(-1px);
      border-color: rgba(251, 191, 36, 0.35);
      background: linear-gradient(180deg, #1b2f50, #152640);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 20px;
    }

    .stat-card {
      background: linear-gradient(180deg, rgba(20,33,57,0.98), rgba(14,25,45,0.98));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 16px;
      box-shadow: var(--shadow);
      min-height: 106px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .stat-title {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 28px;
      font-weight: bold;
      color: #fff;
      line-height: 1.1;
    }

    .stat-value.gold {
      color: var(--accent);
    }

    .main-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.65fr) minmax(350px, 0.9fr);
      gap: 20px;
      align-items: start;
    }

    .panel {
      background: linear-gradient(180deg, rgba(20,33,57,0.96), rgba(14,25,45,0.96));
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: var(--shadow);
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 18px 18px 0 18px;
      flex-wrap: wrap;
    }

    .panel-head h2 {
      margin: 0;
      font-size: 27px;
      color: var(--accent);
    }

    .panel-sub {
      color: var(--muted);
      font-size: 14px;
    }

    .products-panel {
      overflow: hidden;
    }

    .tools-row {
      display: grid;
      grid-template-columns: 1fr 220px;
      gap: 12px;
      padding: 16px 18px 0 18px;
    }

    .search-input,
    .select-input,
    .note-input,
    .text-input {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #edf2fb;
      color: #0f172a;
      border-radius: 14px;
      padding: 13px 14px;
      font-size: 15px;
      outline: none;
    }

    .search-input:focus,
    .select-input:focus,
    .note-input:focus,
    .text-input:focus {
      border-color: rgba(59,130,246,0.4);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .products-scroll {
      padding: 18px;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      max-height: 66vh;
      overflow-y: auto;
      padding-right: 4px;
    }

    .products-grid::-webkit-scrollbar {
      width: 8px;
    }

    .products-grid::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .product-card {
      background: linear-gradient(180deg, #0c1830, #0a152a);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 18px;
      padding: 14px;
      transition: 0.18s ease;
    }

    .product-card:hover {
      transform: translateY(-2px);
      border-color: rgba(251,191,36,0.22);
    }

    .product-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .product-name {
      font-size: 18px;
      font-weight: bold;
      color: #fff;
      line-height: 1.2;
      word-break: break-word;
    }

    .badge {
      background: rgba(251,191,36,0.14);
      color: var(--accent);
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: bold;
      white-space: nowrap;
      border: 1px solid rgba(251,191,36,0.18);
    }

    .product-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      margin: 12px 0 14px;
    }

    .meta-box {
      background: rgba(255,255,255,0.04);
      border-radius: 12px;
      padding: 10px;
      border: 1px solid rgba(255,255,255,0.04);
    }

    .meta-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .meta-value {
      font-size: 14px;
      color: #fff;
      font-weight: bold;
      word-break: break-word;
    }

    .inputs-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 10px;
    }

    .add-btn {
      width: 100%;
      border: none;
      border-radius: 14px;
      padding: 12px;
      background: linear-gradient(180deg, var(--accent), #f2b21b);
      color: #111827;
      font-weight: bold;
      font-size: 15px;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .add-btn:hover {
      background: linear-gradient(180deg, #ffca38, #ecb11c);
      transform: translateY(-1px);
    }

    .cart-panel {
      position: sticky;
      top: 18px;
      padding-bottom: 18px;
    }

    .cart-head {
      padding: 18px 18px 0 18px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }

    .cart-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 29px;
    }

    .cart-count {
      background: rgba(34,197,94,0.16);
      color: #86efac;
      border: 1px solid rgba(34,197,94,0.20);
      padding: 8px 12px;
      border-radius: 999px;
      font-weight: bold;
      font-size: 13px;
    }

    .cart-body {
      padding: 16px 18px 0 18px;
    }

    .cart-list {
      display: grid;
      gap: 10px;
      max-height: 270px;
      overflow-y: auto;
      margin-bottom: 14px;
      padding-right: 4px;
    }

    .cart-list::-webkit-scrollbar {
      width: 8px;
    }

    .cart-list::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .cart-item {
      background: linear-gradient(180deg, #0c1830, #0a152a);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 12px;
    }

    .cart-item-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 6px;
    }

    .cart-title {
      font-weight: bold;
      font-size: 15px;
      color: #fff;
    }

    .cart-price {
      color: var(--accent);
      font-weight: bold;
      white-space: nowrap;
    }

    .cart-meta {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.45;
    }

    .cart-remove {
      margin-top: 10px;
      border: none;
      background: linear-gradient(180deg, var(--red), var(--red-dark));
      color: white;
      padding: 9px 12px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: bold;
      font-size: 13px;
    }

    .cart-remove:hover {
      filter: brightness(1.05);
    }

    .empty-box,
    .empty-cart {
      background: linear-gradient(180deg, #0d1930, #0a152a);
      border: 1px dashed rgba(255,255,255,0.10);
      color: var(--muted);
      border-radius: 16px;
      padding: 18px;
      font-size: 14px;
      text-align: center;
    }

    .checkout-box {
      background: linear-gradient(180deg, #0b172d, #0a1428);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 18px;
      padding: 16px;
    }

    .field-label {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 8px;
      font-weight: bold;
    }

    .field-block {
      margin-bottom: 14px;
    }

    .note-input {
      min-height: 78px;
      resize: vertical;
    }

    .customer-block {
      margin-bottom: 14px;
      padding: 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.05);
    }

    .total-wrap {
      margin-top: 12px;
      margin-bottom: 14px;
      padding: 14px;
      background: rgba(255,255,255,0.03);
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.05);
    }

    .total-label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .total-price {
      font-size: 34px;
      line-height: 1.1;
      font-weight: bold;
      color: var(--accent);
      word-break: break-word;
    }

    .checkout-btn,
    .secondary-btn {
      width: 100%;
      border: none;
      border-radius: 14px;
      padding: 13px 14px;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .checkout-btn {
      background: linear-gradient(180deg, var(--green), var(--green-dark));
      color: white;
      margin-bottom: 10px;
    }

    .checkout-btn:hover {
      filter: brightness(1.04);
      transform: translateY(-1px);
    }

    .secondary-btn {
      background: linear-gradient(180deg, #2b3b57, #22324d);
      color: white;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .secondary-btn:hover {
      background: linear-gradient(180deg, #324566, #273853);
    }

    .pending-section {
      margin-top: 20px;
      padding: 18px;
    }

    .pending-section h2 {
      margin: 0 0 6px;
      color: var(--accent);
      font-size: 26px;
    }

    .pending-sub {
      margin-bottom: 14px;
      color: var(--muted);
      font-size: 14px;
    }

    .pending-list {
      display: grid;
      gap: 14px;
    }

    .pending-card {
      background: linear-gradient(180deg, #0d1930, #0a152a);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 18px;
      padding: 14px;
    }

    .pending-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .pending-info {
      display: grid;
      gap: 5px;
      color: #dbe8ff;
      font-size: 14px;
    }

    .pending-sum {
      font-size: 24px;
      font-weight: bold;
      color: var(--accent);
      white-space: nowrap;
    }

    .pending-items {
      display: grid;
      gap: 8px;
    }

    .item {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px 12px;
      font-size: 14px;
      color: #d9e4f7;
    }

    .row-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .row-actions form {
      margin: 0;
    }

    .approve-btn,
    .reject-btn {
      border: none;
      border-radius: 12px;
      padding: 11px 16px;
      font-weight: bold;
      cursor: pointer;
      color: white;
      font-size: 14px;
    }

    .approve-btn {
      background: linear-gradient(180deg, var(--green), var(--green-dark));
    }

    .reject-btn {
      background: linear-gradient(180deg, var(--red), var(--red-dark));
    }

    .approve-btn:hover,
    .reject-btn:hover {
      filter: brightness(1.05);
    }

    .footer-note {
      margin-top: 18px;
      text-align: center;
      color: rgba(255,255,255,0.38);
      font-size: 13px;
    }

    @media (max-width: 1200px) {
      .stats-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .main-grid {
        grid-template-columns: 1fr;
      }

      .cart-panel {
        position: static;
      }
    }

    @media (max-width: 900px) {
      .products-grid {
        grid-template-columns: 1fr;
        max-height: none;
      }

      .tools-row {
        grid-template-columns: 1fr;
      }

      .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .header-left h1 {
        font-size: 29px;
      }
    }

    @media (max-width: 560px) {
      .wrapper {
        padding: 14px;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .inputs-row {
        grid-template-columns: 1fr;
      }

      .nav-links {
        justify-content: flex-start;
      }

      .panel-head h2,
      .cart-head h2,
      .pending-section h2 {
        font-size: 23px;
      }

      .total-price {
        font-size: 28px;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="header-left">
        <h1>Sotuvchi paneli</h1>
        <p>Professional kassa oynasi — mahsulot, savat va savdoni tez boshqarish uchun.</p>
      </div>

      <div class="nav-links">
        <a href="/seller/sales">Savdolar</a>
        <a href="/seller/debts">Qarzlar</a>
        <a href="/seller/expenses">Chiqimlar</a>
        <a href="/seller/suppliers">Firmalar</a>
        <a href="/seller/stock-entries">Kirimlar</a>
        <a href="/seller/supplier-payments">Firma to‘lovlari</a>
        <a href="/seller/returns">Qaytimlar</a>
        <a href="/seller/supplier-returns">Firma qaytimlari</a>
        <a href="/auth/logout">Chiqish</a>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-title">Jami chiqimlar soni</div>
        <div class="stat-value"><%= expenseCount || 0 %></div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Firmalar soni</div>
        <div class="stat-value"><%= supplierCount || 0 %></div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Jami kirim summasi</div>
        <div class="stat-value"><%= Number(totalStockEntries || 0).toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Firmalarga to‘langan jami</div>
        <div class="stat-value"><%= Number(totalSupplierPayments || 0).toLocaleString("uz-UZ") %></div>
      </div>

      <div class="stat-card">
        <div class="stat-title">Jami chiqim summasi</div>
        <div class="stat-value gold"><%= Number(totalExpenses || 0).toLocaleString("uz-UZ") %></div>
      </div>
    </div>

    <div class="main-grid">
      <div class="panel products-panel">
        <div class="panel-head">
          <div>
            <h2>Mahsulotlar</h2>
            <div class="panel-sub">Mahsulotlar endi ixcham, kassa usulida va ko‘proq ko‘rinadi.</div>
          </div>
        </div>

        <div class="tools-row">
          <input
            type="text"
            id="searchInput"
            class="search-input"
            placeholder="Mahsulot yoki kategoriya bo‘yicha qidirish..."
          />

          <select id="sortSelect" class="select-input">
            <option value="default">Standart tartib</option>
            <option value="name-asc">Nom A-Z</option>
            <option value="price-desc">Narx yuqori</option>
            <option value="price-asc">Narx past</option>
          </select>
        </div>

        <div class="products-scroll">
          <div class="products-grid" id="productsBox">
            <% products.forEach(product => { %>
              <div
                class="product-card"
                data-name="<%= (product.name || '').toLowerCase() %>"
                data-category="<%= (product.category || '').toLowerCase() %>"
                data-id="<%= product._id %>"
                data-product-name="<%= product.name %>"
                data-unit="<%= product.unit %>"
                data-default-price="<%= Number(product.salePrice || 0) %>"
                data-price="<%= Number(product.salePrice || 0) %>"
              >
                <div class="product-top">
                  <div class="product-name"><%= product.name %></div>
                  <div class="badge"><%= product.unit || "-" %></div>
                </div>

                <div class="product-meta">
                  <div class="meta-box">
                    <div class="meta-label">Kategoriya</div>
                    <div class="meta-value"><%= product.category || "-" %></div>
                  </div>
                  <div class="meta-box">
                    <div class="meta-label">Qoldiq</div>
                    <div class="meta-value"><%= Number(product.stock || 0) %></div>
                  </div>
                  <div class="meta-box">
                    <div class="meta-label">Sotuv narxi</div>
                    <div class="meta-value"><%= Number(product.salePrice || 0).toLocaleString("uz-UZ") %></div>
                  </div>
                  <div class="meta-box">
                    <div class="meta-label">Birlik</div>
                    <div class="meta-value"><%= product.unit || "-" %></div>
                  </div>
                </div>

                <div class="inputs-row">
                  <input
                    type="number"
                    step="0.01"
                    placeholder="Miqdor"
                    class="text-input qty-input"
                  />

                  <input
                    type="number"
                    step="0.01"
                    placeholder="Narx"
                    class="text-input price-input"
                    value="<%= Number(product.salePrice || 0) %>"
                  />
                </div>

                <button class="add-btn" type="button">Savatga qo‘shish</button>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="panel cart-panel">
        <div class="cart-head">
          <h2>Savat</h2>
          <div class="cart-count"><span id="cartCount">0</span> ta mahsulot</div>
        </div>

        <div class="cart-body">
          <div id="cartList" class="cart-list">
            <div class="empty-cart">Hozircha savatda mahsulot yo‘q.</div>
          </div>

          <div class="checkout-box">
            <div class="field-block">
              <div class="field-label">To‘lov turi</div>
              <select id="paymentType" class="select-input">
                <option value="cash">Naqd</option>
                <option value="card">Karta</option>
                <option value="transfer">O‘tkazma</option>
                <option value="debt">Nasiya</option>
              </select>
            </div>

            <div id="customerBox" class="customer-block" style="display:none;">
              <div class="field-block" style="margin-bottom: 10px;">
                <div class="field-label">Bazadagi mijoz</div>
                <select id="customerId" class="select-input">
                  <option value="">Mijozni tanlang</option>
                  <% customers.forEach(customer => { %>
                    <option value="<%= customer._id %>">
                      <%= customer.fullName %> - <%= customer.phone %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <button type="button" id="toggleNewCustomerBtn" class="secondary-btn">
                + Yangi mijoz qo‘shish
              </button>

              <div id="newCustomerBox" style="display:none; margin-top: 12px;">
                <div class="field-block">
                  <input
                    type="text"
                    id="newCustomerName"
                    class="text-input"
                    placeholder="Mijoz ismi"
                  />
                </div>

                <div class="field-block">
                  <input
                    type="text"
                    id="newCustomerPhone"
                    class="text-input"
                    placeholder="Telefon raqami"
                  />
                </div>

                <div class="field-block">
                  <input
                    type="text"
                    id="newCustomerAddress"
                    class="text-input"
                    placeholder="Manzil (ixtiyoriy)"
                  />
                </div>

                <div class="field-block" style="margin-bottom: 0;">
                  <textarea
                    id="newCustomerNote"
                    class="note-input"
                    placeholder="Mijoz izohi (ixtiyoriy)"
                  ></textarea>
                </div>
              </div>
            </div>

            <div class="field-block">
              <div class="field-label">Izoh</div>
              <textarea
                id="saleNote"
                class="note-input"
                placeholder="Savdo bo‘yicha izoh yozish mumkin"
              ></textarea>
            </div>

            <div class="total-wrap">
              <div class="total-label">Jami summa</div>
              <div class="total-price" id="totalPrice">0</div>
            </div>

            <button class="checkout-btn" type="button" onclick="checkoutSale()">
              Savdoni yakunlash
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="panel pending-section">
      <h2>Kassaga yuborilgan buyurtmalar</h2>
      <div class="pending-sub">Ishchilar yuborgan buyurtmalar shu yerda tasdiqlanadi yoki rad etiladi.</div>

      <% if (!pendingOrders || pendingOrders.length === 0) { %>
        <div class="empty-box">Hozircha pending orderlar yo‘q.</div>
      <% } else { %>
        <div class="pending-list">
          <% pendingOrders.forEach(order => { %>
            <div class="pending-card">
              <div class="pending-top">
                <div class="pending-info">
                  <div><strong>Ishchi:</strong> <%= order.workerName || "-" %></div>
                  <div><strong>To‘lov turi:</strong> <%= order.paymentType %></div>

                  <% if (order.paymentType === "debt") { %>
                    <div><strong>Mijoz:</strong> <%= order.customerName || "-" %></div>
                    <div><strong>Telefon:</strong> <%= order.customerPhone || "-" %></div>
                  <% } %>

                  <% if (order.note) { %>
                    <div><strong>Izoh:</strong> <%= order.note %></div>
                  <% } %>
                </div>

                <div class="pending-sum">
                  <%= Number(order.totalAmount || 0).toLocaleString("uz-UZ") %>
                </div>
              </div>

              <div class="pending-items">
                <% order.items.forEach(item => { %>
                  <div class="item">
                    <strong><%= item.productName %></strong><br />
                    <%= item.qty %> <%= item.unit %> × <%= Number(item.price || 0).toLocaleString("uz-UZ") %>
                    = <%= Number(item.lineTotal || 0).toLocaleString("uz-UZ") %>
                  </div>
                <% }) %>
              </div>

              <div class="row-actions">
                <form action="/seller/pending-orders/<%= order._id %>/approve" method="POST">
                  <button class="approve-btn" type="submit">Tasdiqlash</button>
                </form>

                <form action="/seller/pending-orders/<%= order._id %>/reject" method="POST">
                  <button class="reject-btn" type="submit">Rad etish</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="footer-note">© 2026 SharqTech. Barcha huquqlar himoyalangan.</div>
  </div>

  <script>
    const cart = [];

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("uz-UZ");
    }

    function renderCart() {
      const cartList = document.getElementById("cartList");
      const totalPrice = document.getElementById("totalPrice");
      const cartCount = document.getElementById("cartCount");

      cartCount.textContent = cart.length;

      if (cart.length === 0) {
        cartList.innerHTML = '<div class="empty-cart">Hozircha savatda mahsulot yo‘q.</div>';
        totalPrice.textContent = "0";
        return;
      }

      cartList.innerHTML = "";
      let total = 0;

      cart.forEach((item, index) => {
        total += Number(item.lineTotal || 0);

        const div = document.createElement("div");
        div.className = "cart-item";
        div.innerHTML = `
          <div class="cart-item-top">
            <div class="cart-title">${item.name}</div>
            <div class="cart-price">${formatMoney(item.lineTotal)}</div>
          </div>
          <div class="cart-meta">
            ${item.qty} ${item.unit} × ${formatMoney(item.price)}
          </div>
          <button class="cart-remove" onclick="removeFromCart(${index})">O‘chirish</button>
        `;
        cartList.appendChild(div);
      });

      totalPrice.textContent = formatMoney(total);
    }

    function addToCartFromCard(card) {
      const productId = card.dataset.id;
      const name = card.dataset.productName;
      const unit = card.dataset.unit;
      const defaultPrice = Number(card.dataset.defaultPrice || 0);

      const qtyInput = card.querySelector(".qty-input");
      const priceInput = card.querySelector(".price-input");

      const qty = Number(qtyInput.value);
      const price = Number(priceInput.value || defaultPrice);

      if (!qty || qty <= 0) {
        alert("Miqdorni to‘g‘ri kiriting");
        return;
      }

      if (!price || price <= 0) {
        alert("Narxni to‘g‘ri kiriting");
        return;
      }

      const lineTotal = qty * price;

      cart.push({
        productId,
        name,
        unit,
        qty,
        price,
        lineTotal
      });

      qtyInput.value = "";
      renderCart();
    }

    function removeFromCart(index) {
      cart.splice(index, 1);
      renderCart();
    }

    async function checkoutSale() {
      if (cart.length === 0) {
        alert("Savat bo‘sh");
        return;
      }

      const paymentType = document.getElementById("paymentType").value;
      const note = document.getElementById("saleNote").value;
      const customerId = document.getElementById("customerId")
        ? document.getElementById("customerId").value
        : "";

      const newCustomer = {
        fullName: document.getElementById("newCustomerName")
          ? document.getElementById("newCustomerName").value
          : "",
        phone: document.getElementById("newCustomerPhone")
          ? document.getElementById("newCustomerPhone").value
          : "",
        address: document.getElementById("newCustomerAddress")
          ? document.getElementById("newCustomerAddress").value
          : "",
        note: document.getElementById("newCustomerNote")
          ? document.getElementById("newCustomerNote").value
          : ""
      };

      if (paymentType === "debt") {
        const hasSelectedCustomer = !!customerId;
        const hasNewCustomer =
          newCustomer.fullName.trim() && newCustomer.phone.trim();

        if (!hasSelectedCustomer && !hasNewCustomer) {
          alert("Nasiyaga savdo uchun mijoz tanlang yoki yangi mijoz kiriting");
          return;
        }
      }

      try {
        const response = await fetch("/seller/checkout", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            items: cart,
            paymentType,
            note,
            customerId,
            newCustomer
          })
        });

        const result = await response.json();

        if (!result.success) {
          alert(result.message || "Xatolik yuz berdi");
          return;
        }

        alert(result.message || "Savdo muvaffaqiyatli saqlandi");

        cart.length = 0;
        document.getElementById("saleNote").value = "";
        document.getElementById("paymentType").value = "cash";

        if (document.getElementById("customerId")) {
          document.getElementById("customerId").value = "";
        }

        if (document.getElementById("newCustomerName")) {
          document.getElementById("newCustomerName").value = "";
          document.getElementById("newCustomerPhone").value = "";
          document.getElementById("newCustomerAddress").value = "";
          document.getElementById("newCustomerNote").value = "";
        }

        renderCart();
        toggleCustomerBox();
        window.location.reload();
      } catch (error) {
        console.error(error);
        alert("Server bilan bog‘lanishda xatolik");
      }
    }

    const searchInput = document.getElementById("searchInput");
    const sortSelect = document.getElementById("sortSelect");
    const productsBox = document.getElementById("productsBox");

    function getProductCards() {
      return Array.from(document.querySelectorAll(".product-card"));
    }

    function filterProducts() {
      const value = searchInput.value.toLowerCase().trim();
      const cards = getProductCards();

      cards.forEach(card => {
        const name = card.dataset.name || "";
        const category = card.dataset.category || "";

        if (name.includes(value) || category.includes(value)) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });
    }

    function sortProducts() {
      const value = sortSelect.value;
      const cards = getProductCards();

      cards.sort((a, b) => {
        const nameA = a.dataset.name || "";
        const nameB = b.dataset.name || "";
        const priceA = Number(a.dataset.price || 0);
        const priceB = Number(b.dataset.price || 0);

        if (value === "name-asc") return nameA.localeCompare(nameB);
        if (value === "price-desc") return priceB - priceA;
        if (value === "price-asc") return priceA - priceB;
        return 0;
      });

      cards.forEach(card => productsBox.appendChild(card));
      filterProducts();
    }

    searchInput.addEventListener("input", filterProducts);
    sortSelect.addEventListener("change", sortProducts);

    document.querySelectorAll(".add-btn").forEach(button => {
      button.addEventListener("click", function () {
        const card = this.closest(".product-card");
        addToCartFromCard(card);
      });
    });

    const paymentTypeSelect = document.getElementById("paymentType");
    const customerBox = document.getElementById("customerBox");
    const toggleNewCustomerBtn = document.getElementById("toggleNewCustomerBtn");
    const newCustomerBox = document.getElementById("newCustomerBox");
    const customerSelect = document.getElementById("customerId");

    function toggleCustomerBox() {
      if (paymentTypeSelect.value === "debt") {
        customerBox.style.display = "block";
      } else {
        customerBox.style.display = "none";
        newCustomerBox.style.display = "none";
      }
    }

    if (toggleNewCustomerBtn) {
      toggleNewCustomerBtn.addEventListener("click", function () {
        if (
          newCustomerBox.style.display === "none" ||
          newCustomerBox.style.display === ""
        ) {
          newCustomerBox.style.display = "block";
          if (customerSelect) {
            customerSelect.value = "";
          }
        } else {
          newCustomerBox.style.display = "none";
        }
      });
    }

    if (customerSelect) {
      customerSelect.addEventListener("change", function () {
        if (this.value) {
          newCustomerBox.style.display = "none";
        }
      });
    }

    paymentTypeSelect.addEventListener("change", toggleCustomerBox);
    toggleCustomerBox();
    renderCart();
  </script>
</body>
</html>
