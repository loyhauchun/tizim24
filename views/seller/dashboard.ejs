<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kassa</title>

  <style>
    :root {
      --bg: #06111f;
      --panel: #0d1c33;
      --panel-2: #09162b;
      --line: rgba(255, 255, 255, 0.08);
      --line-soft: rgba(255, 255, 255, 0.05);
      --text: #eef4ff;
      --muted: #8ea4c7;
      --accent: #fbbf24;
      --accent-2: #ffd15f;
      --green: #22c55e;
      --green-2: #16a34a;
      --red: #ef4444;
      --red-2: #dc2626;
      --shadow: 0 14px 38px rgba(0, 0, 0, 0.28);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow: hidden;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(59,130,246,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 24%),
        var(--bg);
      color: var(--text);
    }

    body {
      min-height: 100vh;
    }

    .wrapper {
      max-width: 1680px;
      margin: 0 auto;
      height: 100vh;
      padding: 8px 12px 30px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      overflow: hidden;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      min-height: 50px;
      flex: 0 0 auto;
    }

    .brand {
      margin: 0;
      font-size: 30px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.8px;
      color: var(--accent);
    }

    .topbar-right {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .menu-toggle {
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #182c4b, #12213a);
      color: white;
      border-radius: 14px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.18s ease;
      box-shadow: var(--shadow);
      padding: 0;
    }

    .menu-toggle:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.22);
    }

    .menu-bars {
      width: 18px;
      height: 14px;
      display: grid;
      gap: 4px;
    }

    .menu-bars span {
      display: block;
      height: 2px;
      background: #fff;
      border-radius: 999px;
    }

    .menu-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      width: 270px;
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 10px;
      display: none;
      z-index: 100;
    }

    .menu-dropdown.open {
      display: block;
      animation: fadeDown 0.18s ease;
    }

    @keyframes fadeDown {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .menu-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      margin: 4px 6px 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .menu-links {
      display: grid;
      gap: 8px;
    }

    .menu-links a {
      text-decoration: none;
      color: white;
      background: linear-gradient(180deg, #142540, #102038);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      transition: 0.18s ease;
    }

    .menu-links a:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, #1a2f50, #152741);
      border-color: rgba(251,191,36,0.20);
    }

    .workspace {
      flex: 1;
      min-height: 0;
      display: grid;
      grid-template-columns: minmax(250px, 0.8fr) minmax(540px, 1.5fr) minmax(305px, 0.82fr);
      gap: 10px;
      overflow: hidden;
    }

    .column {
      min-height: 0;
      overflow: hidden;
    }

    .panel {
      height: 100%;
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .panel-head {
      padding: 12px 14px 8px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      flex: 0 0 auto;
    }

    .panel-head h2 {
      margin: 0;
      color: var(--accent);
      font-size: 18px;
      line-height: 1.05;
    }

    .panel-head .small-note {
      margin-top: 3px;
      color: var(--muted);
      font-size: 11px;
    }

    .search-row {
      padding: 10px 14px 8px;
      display: grid;
      gap: 8px;
      flex: 0 0 auto;
    }

    .search-input,
    .select-input,
    .text-input,
    .note-input,
    .mini-input {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.08);
      background: #eef3fb;
      color: #0f172a;
      border-radius: 12px;
      padding: 10px 11px;
      font-size: 13px;
      outline: none;
    }

    .search-input:focus,
    .select-input:focus,
    .text-input:focus,
    .note-input:focus,
    .mini-input:focus {
      border-color: rgba(59,130,246,0.42);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .category-dropdown-wrap {
      position: relative;
    }

    .category-toggle {
      width: 100%;
      height: 40px;
      border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, #12213a, #0f1c33);
      color: #dce8fb;
      border-radius: 12px;
      padding: 0 12px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .category-toggle:hover {
      border-color: rgba(251,191,36,0.18);
    }

    .category-toggle span:last-child {
      color: var(--accent);
      font-size: 12px;
    }

    .category-dropdown {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 8px);
      background: linear-gradient(180deg, rgba(18,32,56,0.98), rgba(11,21,41,0.98));
      border: 1px solid var(--line);
      border-radius: 16px;
      box-shadow: var(--shadow);
      padding: 8px;
      display: none;
      z-index: 40;
      max-height: 220px;
      overflow-y: auto;
    }

    .category-dropdown.open {
      display: grid;
      gap: 6px;
    }

    .category-item {
      width: 100%;
      text-align: left;
      border: 1px solid rgba(255,255,255,0.08);
      background: #12213a;
      color: #d7e7ff;
      border-radius: 10px;
      padding: 9px 11px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .category-item:hover {
      background: #182c4c;
    }

    .category-item.active {
      background: linear-gradient(180deg, var(--accent), #f1b61e);
      color: #131923;
      border-color: rgba(251,191,36,0.24);
    }

    .product-list-box {
      flex: 1;
      min-height: 0;
      background: linear-gradient(180deg, #0b1730, #081426);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 16px;
      margin: 0 14px 14px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .inner-head {
      padding: 9px 11px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: var(--muted);
      font-size: 11px;
      font-weight: 700;
      flex: 0 0 auto;
    }

    .product-list,
    .sale-table-body,
    .summary-scroll,
    .extra-scroll,
    .push-stack,
    .low-stock-stack {
      scrollbar-width: thin;
    }

    .product-list::-webkit-scrollbar,
    .sale-table-body::-webkit-scrollbar,
    .summary-scroll::-webkit-scrollbar,
    .extra-scroll::-webkit-scrollbar,
    .push-stack::-webkit-scrollbar,
    .low-stock-stack::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    .product-list::-webkit-scrollbar-thumb,
    .sale-table-body::-webkit-scrollbar-thumb,
    .summary-scroll::-webkit-scrollbar-thumb,
    .extra-scroll::-webkit-scrollbar-thumb,
    .push-stack::-webkit-scrollbar-thumb,
    .low-stock-stack::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.10);
      border-radius: 999px;
    }

    .product-list {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      padding: 7px;
      display: grid;
      gap: 7px;
      align-content: start;
    }

    .product-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 8px;
      align-items: center;
      background: linear-gradient(180deg, #0d1b33, #0a162b);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 8px 10px;
      transition: 0.18s ease;
      min-height: 54px;
    }

    .product-row:hover {
      transform: translateY(-1px);
      border-color: rgba(251,191,36,0.16);
    }

    .product-name {
      font-size: 13px;
      font-weight: 800;
      color: white;
      line-height: 1.15;
      margin-bottom: 2px;
      word-break: break-word;
    }

    .product-cat {
      font-size: 11px;
      color: var(--muted);
      word-break: break-word;
    }

    .add-mini-btn {
      width: 34px;
      height: 34px;
      border: none;
      border-radius: 10px;
      background: linear-gradient(180deg, var(--accent), #efb318);
      color: #101722;
      font-size: 22px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }

    .add-mini-btn:hover {
      transform: scale(1.03);
      background: linear-gradient(180deg, var(--accent-2), #f1b61e);
    }

    .sale-table-wrap {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      padding: 10px 14px 14px;
      gap: 7px;
      overflow: hidden;
    }

    .sale-table-head,
    .sale-table-row {
      display: grid;
      grid-template-columns: minmax(135px, 1.7fr) 95px 124px 95px 84px;
      gap: 6px;
      align-items: center;
    }

    .sale-table-head {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 8px 10px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      flex: 0 0 auto;
    }

    .sale-table-body {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      overflow-x: hidden;
      display: grid;
      gap: 7px;
      align-content: start;
      padding-right: 2px;
    }

    .sale-empty {
      background: linear-gradient(180deg, #0b1831, #081528);
      border: 1px dashed rgba(255,255,255,0.10);
      border-radius: 12px;
      color: var(--muted);
      font-size: 13px;
      padding: 16px;
      text-align: center;
    }

    .sale-table-row {
      background: linear-gradient(180deg, #0d1b33, #0a162b);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 8px 10px;
      min-height: 56px;
    }

    .sale-product-name {
      font-size: 13px;
      font-weight: 800;
      color: white;
      line-height: 1.15;
      word-break: break-word;
    }

    .sale-product-meta {
      font-size: 10px;
      color: var(--muted);
      margin-top: 2px;
    }

    .line-total-cell {
      color: var(--accent);
      font-size: 13px;
      font-weight: 800;
      word-break: break-word;
    }

    .qty-cell {
      display: grid;
      grid-template-columns: 28px 1fr 28px;
      gap: 5px;
      align-items: center;
    }

    .qty-btn,
    .remove-btn {
      border: none;
      cursor: pointer;
      font-weight: 800;
      border-radius: 9px;
      transition: 0.18s ease;
      padding: 0;
    }

    .qty-btn {
      width: 28px;
      height: 28px;
      background: #1c3050;
      color: white;
      font-size: 16px;
    }

    .qty-btn:hover {
      background: #27416a;
    }

    .remove-btn {
      width: 100%;
      height: 30px;
      background: linear-gradient(180deg, var(--red), var(--red-2));
      color: white;
      font-size: 11px;
      white-space: nowrap;
    }

    .remove-btn:hover {
      filter: brightness(1.05);
    }

    .summary-body {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      padding: 10px 14px 14px;
      gap: 8px;
    }

    .summary-scroll {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      display: grid;
      gap: 8px;
      padding-right: 2px;
      align-content: start;
    }

    .summary-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px;
    }

    .summary-label {
      color: var(--muted);
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 5px;
    }

    .summary-value {
      font-size: 16px;
      font-weight: 800;
      color: white;
      line-height: 1.1;
      word-break: break-word;
    }

    .summary-value.gold {
      color: var(--accent);
      font-size: 24px;
    }

    .payment-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 7px;
    }

    .payment-btn {
      border: 1px solid rgba(255,255,255,0.07);
      background: #12213a;
      color: #dce8fb;
      border-radius: 10px;
      padding: 9px 8px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .payment-btn.active {
      background: linear-gradient(180deg, var(--accent), #f0b61d);
      color: #101722;
      border-color: rgba(251,191,36,0.22);
    }

    .extra-panel {
      display: none;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 9px;
    }

    .extra-panel.open {
      display: block;
    }

    .extra-scroll {
      max-height: 170px;
      overflow-y: auto;
      padding-right: 2px;
    }

    .field-block {
      margin-bottom: 8px;
    }

    .field-block:last-child {
      margin-bottom: 0;
    }

    .field-label {
      font-size: 11px;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 5px;
    }

    .note-input {
      min-height: 58px;
      resize: vertical;
    }

    .customer-box {
      display: none;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 10px;
      padding: 9px;
      margin-top: 8px;
    }

    .secondary-btn,
    .ghost-btn,
    .checkout-btn {
      border: none;
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .secondary-btn,
    .ghost-btn {
      background: linear-gradient(180deg, #233754, #1a2c46);
      color: white;
      border: 1px solid rgba(255,255,255,0.07);
    }

    .secondary-btn {
      width: 100%;
      margin-top: 7px;
      padding: 9px 11px;
      font-size: 12px;
    }

    .ghost-btn:hover,
    .checkout-btn:hover,
    .secondary-btn:hover {
      transform: translateY(-1px);
    }

    .summary-footer {
      flex: 0 0 auto;
      display: grid;
      gap: 8px;
      padding-top: 2px;
      background: linear-gradient(180deg, rgba(13,28,51,0.15), rgba(13,28,51,0.85));
    }

    .checkout-btn {
      width: 100%;
      background: linear-gradient(180deg, var(--green), var(--green-2));
      color: white;
      box-shadow: 0 8px 18px rgba(34,197,94,0.18);
    }

    .push-stack {
      position: fixed;
      right: 14px;
      top: 64px;
      width: 340px;
      max-height: calc(100vh - 110px);
      overflow-y: auto;
      display: grid;
      gap: 10px;
      z-index: 70;
      padding-right: 2px;
    }

    .push-card {
      background: linear-gradient(180deg, rgba(16,30,52,0.98), rgba(11,21,41,0.98));
      border: 1px solid rgba(251,191,36,0.18);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 12px;
    }

    .push-card.low-stock {
      border-color: rgba(239,68,68,0.18);
    }

    .push-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .push-title {
      font-size: 14px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
    }

    .push-card.low-stock .push-title {
      color: #fda4af;
    }

    .push-close {
      border: none;
      background: rgba(255,255,255,0.06);
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
    }

    .push-info {
      display: grid;
      gap: 4px;
      font-size: 13px;
      color: #dbe8fd;
      margin-bottom: 8px;
    }

    .push-sum {
      color: #fff;
      font-weight: 800;
    }

    .push-items {
      display: grid;
      gap: 6px;
      margin-bottom: 10px;
    }

    .push-item {
      background: rgba(255,255,255,0.04);
      border-radius: 10px;
      padding: 8px 9px;
      font-size: 12px;
      color: #dbe7fb;
      line-height: 1.35;
    }

    .push-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .push-actions form {
      margin: 0;
      flex: 1;
    }

    .approve-btn,
    .reject-btn {
      width: 100%;
      border: none;
      border-radius: 11px;
      padding: 10px 12px;
      color: white;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
    }

    .approve-btn {
      background: linear-gradient(180deg, var(--green), var(--green-2));
    }

    .reject-btn {
      background: linear-gradient(180deg, var(--red), var(--red-2));
    }

    .low-stock-stack {
      position: fixed;
      left: 14px;
      bottom: 14px;
      width: 300px;
      max-height: 250px;
      overflow-y: auto;
      display: grid;
      gap: 10px;
      z-index: 69;
      padding-right: 2px;
    }

    .signature {
      position: fixed;
      right: 16px;
      bottom: 8px;
      color: rgba(255,255,255,0.35);
      font-size: 12px;
      letter-spacing: 0.5px;
      user-select: none;
      pointer-events: none;
    }

    @media (max-width: 1450px) {
      .workspace {
        grid-template-columns: minmax(230px, 0.72fr) minmax(500px, 1.55fr) minmax(295px, 0.8fr);
      }

      .sale-table-head,
      .sale-table-row {
        grid-template-columns: minmax(130px, 1.7fr) 88px 118px 88px 78px;
      }
    }

    @media (max-width: 1200px) {
      html, body {
        overflow: auto;
      }

      .wrapper {
        height: auto;
        min-height: 100vh;
        overflow: visible;
      }

      .workspace {
        grid-template-columns: 1fr;
      }

      .panel {
        height: auto;
        min-height: 420px;
      }

      .sale-table-body,
      .product-list,
      .summary-scroll,
      .extra-scroll {
        max-height: none;
      }

      .push-stack,
      .low-stock-stack {
        position: static;
        width: auto;
        max-height: none;
        margin: 0 12px 10px;
      }
    }

    @media (max-width: 860px) {
      .sale-table-head,
      .sale-table-row {
        grid-template-columns: 1fr;
      }

      .sale-table-head {
        display: none;
      }

      .sale-table-row {
        gap: 8px;
      }

      .brand {
        font-size: 26px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const safeCustomers = Array.isArray(customers) ? customers : [];
    const safePendingOrders = Array.isArray(pendingOrders) ? pendingOrders : [];

    const categoryMap = {};
    safeProducts.forEach(product => {
      const cat = String(product.category || "").trim();
      if (cat) categoryMap[cat] = true;
    });
    const categoryList = Object.keys(categoryMap);

    const lowStockProducts = safeProducts.filter(product => Number(product.stock || 0) < 10);

    function formatStockValue(value) {
      const n = Number(value || 0);
      if (!Number.isFinite(n)) return "0.0";
      return (Math.round(n * 10) / 10).toFixed(1);
    }
  %>

  <div class="wrapper">
    <div class="topbar">
      <h1 class="brand">Kassa</h1>

      <div class="topbar-right">
        <button type="button" class="menu-toggle" id="menuToggle" title="Bo‘limlar">
          <span class="menu-bars">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>

        <div class="menu-dropdown" id="menuDropdown">
          <div class="menu-title">Bo‘limlar</div>
          <div class="menu-links">
            <a href="/seller/sales">Savdolar</a>
            <a href="/seller/debts">Qarzlar</a>
            <a href="/seller/expenses">Chiqimlar</a>
            <a href="/seller/suppliers">Firmalar</a>
            <a href="/seller/stock-entries">Kirimlar</a>
            <a href="/seller/supplier-payments">Firma to‘lovlari</a>
            <a href="/seller/returns">Qaytimlar</a>
            <a href="/seller/supplier-returns">Firma qaytimlari</a>
            <a href="/auth/logout">Chiqish</a>
          </div>
        </div>
      </div>
    </div>

    <div class="workspace">
      <!-- CHAP -->
      <div class="column">
        <div class="panel">
          <div class="panel-head">
            <h2>Mahsulotlar</h2>
          </div>

          <div class="search-row">
            <input
              type="text"
              id="searchInput"
              class="search-input"
              placeholder="Mahsulot yoki kategoriya bo‘yicha qidirish..."
            />

            <div class="category-dropdown-wrap">
              <button type="button" class="category-toggle" id="categoryToggle">
                <span id="categoryToggleText">Kategoriya: Barchasi</span>
                <span>▼</span>
              </button>

              <div class="category-dropdown" id="categoryDropdown">
                <button class="category-item active" type="button" data-category="all">Barchasi</button>

                <% categoryList.forEach(category => { %>
                  <button
                    class="category-item"
                    type="button"
                    data-category="<%= category.toLowerCase() %>"
                  >
                    <%= category %>
                  </button>
                <% }) %>
              </div>
            </div>
          </div>

          <div class="product-list-box">
            <div class="inner-head">Mahsulotni tanlang</div>

            <div class="product-list" id="productList">
              <% safeProducts.forEach(product => { %>
                <div
                  class="product-row"
                  data-name="<%= String(product.name || '').toLowerCase() %>"
                  data-category="<%= String(product.category || '').toLowerCase() %>"
                  data-id="<%= product._id %>"
                  data-product-name="<%= product.name %>"
                  data-unit="<%= product.unit || '-' %>"
                  data-default-price="<%= Number(product.salePrice || 0) %>"
                >
                  <div>
                    <div class="product-name"><%= product.name %></div>
                    <div class="product-cat"><%= product.category || "Kategoriya yo‘q" %></div>
                  </div>

                  <button class="add-mini-btn" type="button">+</button>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <!-- O'RTA -->
      <div class="column">
        <div class="panel">
          <div class="panel-head">
            <h2>Savdo savati</h2>
            <div class="small-note">Ko‘p tovar bo‘lsa faqat shu ro‘yxat ichida scroll bo‘ladi.</div>
          </div>

          <div class="sale-table-wrap">
            <div class="sale-table-head">
              <div>Tovar</div>
              <div>Narx</div>
              <div>Soni</div>
              <div>Jami</div>
              <div>Harakat</div>
            </div>

            <div class="sale-table-body" id="cartList">
              <div class="sale-empty">Hozircha savatda mahsulot yo‘q.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- O'NG -->
      <div class="column">
        <div class="panel">
          <div class="panel-head">
            <h2>Umumiy hisob</h2>
            <div class="small-note"><span id="cartCount">0</span> ta mahsulot</div>
          </div>

          <div class="summary-body">
            <div class="summary-scroll">
              <div class="summary-card">
                <div class="summary-label">To‘lov turi</div>
                <div class="payment-row">
                  <button class="payment-btn active" type="button" data-payment="cash">Naqd</button>
                  <button class="payment-btn" type="button" data-payment="card">Karta</button>
                  <button class="payment-btn" type="button" data-payment="transfer">O‘tkazma</button>
                  <button class="payment-btn" type="button" data-payment="debt">Nasiya</button>
                </div>
                <input type="hidden" id="paymentTypeValue" value="cash" />
              </div>

              <div class="summary-card">
                <div class="summary-label">Mahsulotlar jami</div>
                <div class="summary-value" id="subTotalPrice">0</div>
              </div>

              <div class="summary-card">
  <div class="summary-label">Qo‘shimcha (o‘tib berish)</div>
  <input
    type="number"
    step="0.01"
    min="0"
    id="discountInput"
    class="mini-input"
    value="0"
    placeholder="Masalan: 20000"
  />
</div>

              <div class="summary-card">
                <div class="summary-label">Yakuniy summa</div>
                <div class="summary-value gold" id="finalTotalPrice">0</div>
              </div>

              

                  <div id="customerBox" class="customer-box">
                    <div class="field-block">
                      <div class="field-label">Bazadagi mijoz</div>
                      <select id="customerId" class="select-input">
                        <option value="">Mijozni tanlang</option>
                        <% safeCustomers.forEach(customer => { %>
                          <option value="<%= customer._id %>">
                            <%= customer.fullName %> - <%= customer.phone %>
                          </option>
                        <% }) %>
                      </select>
                    </div>

                    <button type="button" id="toggleNewCustomerBtn" class="secondary-btn">
                      + Yangi mijoz qo‘shish
                    </button>

                    <div id="newCustomerBox" style="display:none; margin-top: 8px;">
                      <div class="field-block">
                        <input
                          type="text"
                          id="newCustomerName"
                          class="text-input"
                          placeholder="Mijoz ismi"
                        />
                      </div>

                      <div class="field-block">
                        <input
                          type="text"
                          id="newCustomerPhone"
                          class="text-input"
                          placeholder="Telefon raqami"
                        />
                      </div>

                      <div class="field-block">
                        <input
                          type="text"
                          id="newCustomerAddress"
                          class="text-input"
                          placeholder="Manzil (ixtiyoriy)"
                        />
                      </div>

                      <div class="field-block">
                        <textarea
                          id="newCustomerNote"
                          class="note-input"
                          placeholder="Mijoz izohi (ixtiyoriy)"
                        ></textarea>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="summary-footer">
              <button class="ghost-btn" type="button" id="toggleExtraBtn">Qo‘shimcha</button>
              <button class="checkout-btn" type="button" onclick="checkoutSale()">Savdoni yakunlash</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if (safePendingOrders.length) { %>
      <div class="push-stack" id="pushStack">
        <% safePendingOrders.forEach(order => { %>
          <div class="push-card" id="push-<%= order._id %>">
            <div class="push-head">
              <div class="push-title">Yangi buyurtma — <%= order.workerName || "Ishchi" %></div>
              <button type="button" class="push-close" onclick="dismissPush('<%= order._id %>')">×</button>
            </div>

            <div class="push-info">
              <div><strong>To‘lov turi:</strong> <%= order.paymentType %></div>

              <% if (order.paymentType === "debt") { %>
                <div><strong>Mijoz:</strong> <%= order.customerName || "-" %></div>
                <div><strong>Telefon:</strong> <%= order.customerPhone || "-" %></div>
              <% } %>

              <% if (order.note) { %>
                <div><strong>Izoh:</strong> <%= order.note %></div>
              <% } %>

              <div class="push-sum">Jami: <%= Number(order.totalAmount || 0).toLocaleString("uz-UZ") %></div>
            </div>

            <div class="push-items">
              <% order.items.forEach(item => { %>
                <div class="push-item">
                  <strong><%= item.productName %></strong><br />
                  <%= item.qty %> <%= item.unit %> × <%= Number(item.price || 0).toLocaleString("uz-UZ") %>
                  = <%= Number(item.lineTotal || 0).toLocaleString("uz-UZ") %>
                </div>
              <% }) %>
            </div>

            <div class="push-actions">
              <form action="/seller/pending-orders/<%= order._id %>/approve" method="POST">
                <button class="approve-btn" type="submit">Tasdiqlash</button>
              </form>

              <form action="/seller/pending-orders/<%= order._id %>/reject" method="POST">
                <button class="reject-btn" type="submit">Rad etish</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (lowStockProducts.length) { %>
      <div class="low-stock-stack" id="lowStockStack">
        <% lowStockProducts.slice(0, 5).forEach(product => { %>
          <div class="push-card low-stock" id="low-stock-<%= product._id %>">
            <div class="push-head">
              <div class="push-title">Kam qoldi</div>
              <button type="button" class="push-close" onclick="dismissLowStock('<%= product._id %>')">×</button>
            </div>

            <div class="push-info">
              <div><strong>Mahsulot:</strong> <%= product.name %></div>
              <div><strong>Qoldiq:</strong> <%= formatStockValue(product.stock) %> <%= product.unit || "" %></div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="signature">SharqTech</div>

  <script>
    const cart = [];
    let activeCategory = "all";

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("uz-UZ");
    }

    function getDiscountValue() {
  const v = Number(document.getElementById("discountInput").value || 0);
  return v > 0 ? v : 0;
}

function calculateTotals() {
  const subTotal = cart.reduce((sum, item) => {
    return sum + (Number(item.qty || 0) * Number(item.price || 0));
  }, 0);

  const discount = getDiscountValue();
  const finalTotal = Math.max(0, subTotal - discount);

  return { subTotal, discount, finalTotal };
}
    function renderCart() {
      const cartList = document.getElementById("cartList");
      const cartCount = document.getElementById("cartCount");
      const subTotalPrice = document.getElementById("subTotalPrice");
      const finalTotalPrice = document.getElementById("finalTotalPrice");

      cartCount.textContent = cart.length;

      if (cart.length === 0) {
        cartList.innerHTML = '<div class="sale-empty">Hozircha savatda mahsulot yo‘q.</div>';
        subTotalPrice.textContent = "0";
        finalTotalPrice.textContent = "0";
        return;
      }

      cartList.innerHTML = cart.map((item, index) => {
        const lineTotal = Number(item.qty || 0) * Number(item.price || 0);

        return `
          <div class="sale-table-row">
            <div>
              <div class="sale-product-name">${item.name}</div>
              <div class="sale-product-meta">${item.unit || "-"}</div>
            </div>

            <div>
              <input
                class="mini-input"
                type="number"
                step="0.01"
                min="0.01"
                value="${item.price}"
                onchange="updateCartPrice(${index}, this.value)"
              />
            </div>

            <div class="qty-cell">
              <button class="qty-btn" type="button" onclick="decreaseQty(${index})">-</button>
              <input
                class="mini-input"
                type="number"
                step="0.01"
                min="0.01"
                value="${item.qty}"
                onchange="updateCartQty(${index}, this.value)"
              />
              <button class="qty-btn" type="button" onclick="increaseQty(${index})">+</button>
            </div>

            <div class="line-total-cell">${formatMoney(lineTotal)}</div>

            <div>
              <button class="remove-btn" type="button" onclick="removeFromCart(${index})">O‘chirish</button>
            </div>
          </div>
        `;
      }).join("");

      const totals = calculateTotals();
      subTotalPrice.textContent = formatMoney(totals.subTotal);
      finalTotalPrice.textContent = formatMoney(totals.finalTotal);
    }

    function addProductToCart(product) {
      const foundIndex = cart.findIndex(item => item.productId === product.productId);

      if (foundIndex > -1) {
        cart[foundIndex].qty = Number(cart[foundIndex].qty || 0) + 1;
      } else {
        cart.push({
          productId: product.productId,
          name: product.name,
          unit: product.unit,
          qty: 1,
          price: Number(product.defaultPrice || 0)
        });
      }

      renderCart();
    }

    function removeFromCart(index) {
      cart.splice(index, 1);
      renderCart();
    }

    function increaseQty(index) {
      cart[index].qty = Number(cart[index].qty || 0) + 1;
      renderCart();
    }

    function decreaseQty(index) {
      const current = Number(cart[index].qty || 0);

      if (current <= 1) {
        cart.splice(index, 1);
      } else {
        cart[index].qty = current - 1;
      }

      renderCart();
    }

    function updateCartQty(index, value) {
      let qty = Number(value);
      if (!qty || qty <= 0) qty = 1;
      cart[index].qty = qty;
      renderCart();
    }

    function updateCartPrice(index, value) {
      let price = Number(value);
      if (!price || price <= 0) price = 1;
      cart[index].price = price;
      renderCart();
    }

    async function checkoutSale() {
      if (cart.length === 0) {
        alert("Savat bo‘sh");
        return;
      }

      const paymentType = document.getElementById("paymentTypeValue").value;
      const note = document.getElementById("saleNote").value;
      const customerId = document.getElementById("customerId")
        ? document.getElementById("customerId").value
        : "";

      const newCustomer = {
        fullName: document.getElementById("newCustomerName")
          ? document.getElementById("newCustomerName").value
          : "",
        phone: document.getElementById("newCustomerPhone")
          ? document.getElementById("newCustomerPhone").value
          : "",
        address: document.getElementById("newCustomerAddress")
          ? document.getElementById("newCustomerAddress").value
          : "",
        note: document.getElementById("newCustomerNote")
          ? document.getElementById("newCustomerNote").value
          : ""
      };

      if (paymentType === "debt") {
        const hasSelectedCustomer = !!customerId;
        const hasNewCustomer =
          newCustomer.fullName.trim() && newCustomer.phone.trim();

        if (!hasSelectedCustomer && !hasNewCustomer) {
          alert("Nasiyaga savdo uchun mijoz tanlang yoki yangi mijoz kiriting");
          return;
        }
      }

      const totals = calculateTotals();

      const items = cart.map(item => ({
        productId: item.productId,
        name: item.name,
        unit: item.unit,
        qty: Number(item.qty || 0),
        price: Number(item.price || 0),
        lineTotal: Number(item.qty || 0) * Number(item.price || 0)
      }));

      try {
        const response = await fetch("/seller/checkout", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            items,
            paymentType,
            note,
            customerId,
            newCustomer,
            discountAmount: totals.discount,
subtotalAmount: totals.subTotal,
finalTotal: totals.finalTotal
          })
        });

        const result = await response.json();

        if (!result.success) {
          alert(result.message || "Xatolik yuz berdi");
          return;
        }

        alert(result.message || "Savdo muvaffaqiyatli saqlandi");

        cart.length = 0;
        document.getElementById("saleNote").value = "";
        document.getElementById("discountInput").value = "0";
        setPaymentType("cash");

        if (document.getElementById("customerId")) {
          document.getElementById("customerId").value = "";
        }

        if (document.getElementById("newCustomerName")) {
          document.getElementById("newCustomerName").value = "";
          document.getElementById("newCustomerPhone").value = "";
          document.getElementById("newCustomerAddress").value = "";
          document.getElementById("newCustomerNote").value = "";
        }

        renderCart();
        toggleCustomerBox();
        window.location.reload();
      } catch (error) {
        console.error(error);
        alert("Server bilan bog‘lanishda xatolik");
      }
    }

    const searchInput = document.getElementById("searchInput");
    const productRows = Array.from(document.querySelectorAll(".product-row"));
    const categoryButtons = Array.from(document.querySelectorAll(".category-item"));
    const categoryToggle = document.getElementById("categoryToggle");
    const categoryDropdown = document.getElementById("categoryDropdown");
    const categoryToggleText = document.getElementById("categoryToggleText");

    function applyProductFilters() {
      const searchValue = (searchInput.value || "").toLowerCase().trim();

      productRows.forEach(row => {
        const name = row.dataset.name || "";
        const category = row.dataset.category || "";

        const matchesSearch =
          !searchValue || name.includes(searchValue) || category.includes(searchValue);

        const matchesCategory =
          activeCategory === "all" || category === activeCategory;

        row.style.display = matchesSearch && matchesCategory ? "" : "none";
      });
    }

    searchInput.addEventListener("input", applyProductFilters);

    if (categoryToggle && categoryDropdown) {
      categoryToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        categoryDropdown.classList.toggle("open");
      });

      categoryDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });
    }

    categoryButtons.forEach(button => {
      button.addEventListener("click", function () {
        categoryButtons.forEach(btn => btn.classList.remove("active"));
        this.classList.add("active");
        activeCategory = this.dataset.category || "all";

        categoryToggleText.textContent =
          activeCategory === "all"
            ? "Kategoriya: Barchasi"
            : `Kategoriya: ${this.textContent.trim()}`;

        categoryDropdown.classList.remove("open");
        applyProductFilters();
      });
    });

    document.addEventListener("click", function () {
      if (categoryDropdown) categoryDropdown.classList.remove("open");
    });

    document.querySelectorAll(".add-mini-btn").forEach(button => {
      button.addEventListener("click", function () {
        const row = this.closest(".product-row");

        addProductToCart({
          productId: row.dataset.id,
          name: row.dataset.productName,
          unit: row.dataset.unit,
          defaultPrice: row.dataset.defaultPrice
        });
      });
    });

    document.querySelectorAll(".product-row").forEach(row => {
      row.addEventListener("dblclick", function () {
        addProductToCart({
          productId: row.dataset.id,
          name: row.dataset.productName,
          unit: row.dataset.unit,
          defaultPrice: row.dataset.defaultPrice
        });
      });
    });

    const discountInput = document.getElementById("discountInput");

if (discountInput) {
  discountInput.addEventListener("input", renderCart);
  discountInput.addEventListener("change", renderCart);
}

    const paymentButtons = Array.from(document.querySelectorAll(".payment-btn"));
    const paymentTypeValue = document.getElementById("paymentTypeValue");
    const extraPanel = document.getElementById("extraPanel");
    const toggleExtraBtn = document.getElementById("toggleExtraBtn");

    function setPaymentType(type) {
      paymentTypeValue.value = type;

      paymentButtons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.payment === type);
      });

      if (type === "debt") {
        extraPanel.classList.add("open");
      }

      toggleCustomerBox();
    }

    paymentButtons.forEach(button => {
      button.addEventListener("click", function () {
        setPaymentType(this.dataset.payment);
      });
    });

    if (toggleExtraBtn) {
      toggleExtraBtn.addEventListener("click", function () {
        extraPanel.classList.toggle("open");
      });
    }

    const customerBox = document.getElementById("customerBox");
    const toggleNewCustomerBtn = document.getElementById("toggleNewCustomerBtn");
    const newCustomerBox = document.getElementById("newCustomerBox");
    const customerSelect = document.getElementById("customerId");

    function toggleCustomerBox() {
      if (paymentTypeValue.value === "debt") {
        customerBox.style.display = "block";
      } else {
        customerBox.style.display = "none";
        newCustomerBox.style.display = "none";
      }
    }

    if (toggleNewCustomerBtn) {
      toggleNewCustomerBtn.addEventListener("click", function () {
        if (
          newCustomerBox.style.display === "none" ||
          newCustomerBox.style.display === ""
        ) {
          newCustomerBox.style.display = "block";
          if (customerSelect) customerSelect.value = "";
        } else {
          newCustomerBox.style.display = "none";
        }
      });
    }

    if (customerSelect) {
      customerSelect.addEventListener("change", function () {
        if (this.value) {
          newCustomerBox.style.display = "none";
        }
      });
    }

    function dismissPush(id) {
      const el = document.getElementById(`push-${id}`);
      if (el) el.remove();
    }

    function dismissLowStock(id) {
      const el = document.getElementById(`low-stock-${id}`);
      if (el) el.remove();
    }

    const menuToggle = document.getElementById("menuToggle");
    const menuDropdown = document.getElementById("menuDropdown");

    if (menuToggle && menuDropdown) {
      menuToggle.addEventListener("click", function (e) {
        e.stopPropagation();
        menuDropdown.classList.toggle("open");
      });

      menuDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });

      document.addEventListener("click", function () {
        menuDropdown.classList.remove("open");
      });
    }

    toggleCustomerBox();
    applyProductFilters();
    renderCart();
  </script>
</body>
</html>
